{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen flex flex-col justify-between">
    <div class="flex flex-col items-center justify-center flex-1">
        <h1 class="mb-6 text-center py-4 text-4xl font-bold">Contactez-nous</h1>
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="p-4 rounded mb-6 {{ label == 'success' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}
        <form method="post" class="max-w-md w-full p-6 border rounded bg-gray-50 mx-auto py-8">
            <label for="email" class="block mb-1">Email</label>
            <input type="email" name="nom" id="nom" class="block w-full border p-2 mb-4 rounded" required>
            <label for="text" class="block mb-1">Sujet</label>
            <input type="text" name="email" id="email" class="block w-full border p-2 mb-4 rounded" required>
            <label for="message" class="block mb-1">Message</label>
            <textarea name="message" id="message" class="block w-full border p-2 mb-4 rounded mb-4" rows="5" required></textarea>
            <div class="flex justify-center">
                <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Envoyer</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
