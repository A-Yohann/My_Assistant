{% extends 'base.html.twig' %}

{% block title %}Liste des devis{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl mt-10 bg-white p-8 rounded shadow">
    <h1 class="text-2xl font-bold mb-6">Liste des devis</h1>
    <table class="min-w-full bg-white">
        <thead>
            <tr>
                <th class="px-4 py-2">Numéro</th>
                <th class="px-4 py-2">Date émission</th>
                <th class="px-4 py-2">Montant HT</th>
                <th class="px-4 py-2">Montant TTC</th>
                <th class="px-4 py-2">Statut</th>
                <th class="px-4 py-2">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for devis in devisList %}
                <tr class="border-b">
                    <td class="px-4 py-2">{{ devis.numeroDevis }}</td>
                    <td class="px-4 py-2">{{ devis.dateEmission|date('d/m/Y') }}</td>
                    <td class="px-4 py-2">{{ devis.montantHT }} €</td>
                    <td class="px-4 py-2">{{ devis.montantTtc }} €</td>
                    <td class="px-4 py-2">{{ devis.status ? 'Payé' : 'En attente' }}</td>
                    <td class="px-4 py-2">
                        <a href="{{ path('devis_show', {'id': devis.id}) }}" class="text-blue-600 hover:underline">Voir</a>
                        <div class="text-xs text-gray-500">Entreprise: {{ devis.entreprise.nomEntreprise ?? 'N/A' }}</div>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center py-4">Aucun devis trouvé.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
