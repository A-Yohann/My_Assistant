{% extends 'base.html.twig' %}

{% block title %}Liste des devis{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl mt-6 lg:mt-10 bg-white p-4 lg:p-8 rounded shadow mx-4 lg:mx-auto">

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-xl lg:text-2xl font-bold">Liste des devis</h1>
        <a href="{{ path('devis_generer') }}" class="bg-[#3B0764] text-white px-4 py-2 rounded text-sm hover:opacity-90">
            + Nouveau devis
        </a>
    </div>

    <!-- Filtres -->
    <form method="GET" action="{{ path('devis_index') }}" class="flex flex-col sm:flex-row gap-3 mb-6">
        <input type="text" name="search" value="{{ search }}"
               placeholder="🔍 Rechercher par numéro ou client..."
               class="flex-1 border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]">

        <select name="statut" class="border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764] bg-white">
            <option value="">Tous les statuts</option>
            <option value="en_attente" {% if statut == 'en_attente' %}selected{% endif %}>En attente</option>
            <option value="valide" {% if statut == 'valide' %}selected{% endif %}>Validé</option>
            <option value="commande" {% if statut == 'commande' %}selected{% endif %}>En attente de paiement</option>
            <option value="paye" {% if statut == 'paye' %}selected{% endif %}>Payé</option>
        </select>

        <button type="submit" class="bg-[#3B0764] text-white px-4 py-2 rounded-lg text-sm hover:opacity-90">
            Filtrer
        </button>

        {% if search or statut %}
            <a href="{{ path('devis_index') }}" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-300">
                Réinitialiser
            </a>
        {% endif %}
    </form>

    <!-- Table desktop -->
    <div class="hidden md:block overflow-x-auto">
        <table class="min-w-full bg-white">
            <thead>
                <tr class="bg-[#3B0764] text-white">
                    <th class="px-4 py-2 text-left">Numéro</th>
                    <th class="px-4 py-2 text-left">Client</th>
                    <th class="px-4 py-2 text-left">Date émission</th>
                    <th class="px-4 py-2 text-left">Montant TTC</th>
                    <th class="px-4 py-2 text-left">Statut</th>
                    <th class="px-4 py-2 text-left">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for devis in devisList %}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="px-4 py-2 font-medium">{{ devis.numeroDevis }}</td>
                        <td class="px-4 py-2 text-sm">{{ devis.client ? devis.client.nom ~ ' ' ~ devis.client.prenom : 'N/A' }}</td>
                        <td class="px-4 py-2">{{ devis.dateEmission|date('d/m/Y') }}</td>
                        <td class="px-4 py-2">{{ devis.montantTtc }} €</td>
                        <td class="px-4 py-2">
                            {% if devis.etat == 'en_attente' %}
                                <span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2 py-1 rounded">En attente</span>
                            {% elseif devis.etat == 'valide' %}
                                <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Validé</span>
                            {% elseif devis.etat == 'commande' %}
                                <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2 py-1 rounded">En attente de paiement</span>
                            {% elseif devis.etat == 'paye' %}
                                <span class="bg-purple-100 text-purple-800 text-xs font-semibold px-2 py-1 rounded">Payé</span>
                            {% else %}
                                <span class="bg-gray-100 text-gray-800 text-xs font-semibold px-2 py-1 rounded">{{ devis.etat }}</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-2">
                            <a href="{{ path('devis_show', {'id': devis.id}) }}" class="text-blue-600 hover:underline text-sm">Voir</a>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="text-center py-4 text-gray-400">Aucun devis trouvé.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Cards mobile -->
    <div class="md:hidden space-y-3">
        {% for devis in devisList %}
            <div class="border rounded-lg p-4 bg-gray-50">
                <div class="flex justify-between items-start mb-2">
                    <span class="font-bold text-[#231F20]">{{ devis.numeroDevis }}</span>
                    {% if devis.etat == 'en_attente' %}
                        <span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2 py-1 rounded">En attente</span>
                    {% elseif devis.etat == 'valide' %}
                        <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Validé</span>
                    {% elseif devis.etat == 'commande' %}
                        <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2 py-1 rounded">En attente de paiement</span>
                    {% elseif devis.etat == 'paye' %}
                        <span class="bg-purple-100 text-purple-800 text-xs font-semibold px-2 py-1 rounded">Payé</span>
                    {% else %}
                        <span class="bg-gray-100 text-gray-800 text-xs font-semibold px-2 py-1 rounded">{{ devis.etat }}</span>
                    {% endif %}
                </div>
                <div class="text-sm text-gray-600 mb-1">👤 {{ devis.client ? devis.client.nom ~ ' ' ~ devis.client.prenom : 'N/A' }}</div>
                <div class="text-sm text-gray-600 mb-1">📅 {{ devis.dateEmission|date('d/m/Y') }}</div>
                <div class="text-sm text-gray-600 mb-3">💰 {{ devis.montantTtc }} €</div>
                <a href="{{ path('devis_show', {'id': devis.id}) }}"
                   class="block text-center bg-[#3B0764] text-white text-sm px-4 py-2 rounded hover:opacity-90">
                    Voir le devis
                </a>
            </div>
        {% else %}
            <p class="text-center text-gray-400 py-4">Aucun devis trouvé.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}