{% extends 'base.html.twig' %}

{% block title %}Générer un devis{% endblock %}

{% block body %}
<div class="container mx-auto max-w-2xl mt-6 lg:mt-10 px-4 mb-10">

    {% for message in app.flashes('success') %}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-2 rounded mb-4">
            {{ message }}
        </div>
    {% endfor %}

    <div class="bg-white rounded-xl shadow p-6 lg:p-8">
        <h1 class="text-2xl font-bold mb-8 text-[#231F20]">Générer un devis</h1>

        {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}

            <!-- Infos devis -->
            <div class="border-b pb-4 mb-2">
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4">Informations du devis</h2>

                <div>
                    {{ form_label(form.numeroDevis, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.numeroDevis, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': 'Ex: DEV-2026-001'}}) }}
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                    <div>
                        {{ form_label(form.dateEmission, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.dateEmission, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.dateValidite, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.dateValidite, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                    <div>
                        {{ form_label(form.montantHT, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.montantHT, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': '0.00'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.dateCreation, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.dateCreation, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                </div>

                <div class="mt-4">
                    {{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.description, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764] resize-none', 'rows': '3', 'placeholder': 'Description du devis...'}}) }}
                </div>

                <div class="mt-4">
                    {{ form_label(form.entreprise, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.entreprise, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764] bg-white'}}) }}
                </div>
            </div>

            <!-- Infos client -->
            <div class="border-b pb-4 mb-2">
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4">Informations du client</h2>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        {{ form_label(form.clientNom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.clientNom, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': 'Dupond'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.clientPrenom, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.clientPrenom, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': 'Jean'}}) }}
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                    <div>
                        {{ form_label(form.clientEmail, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.clientEmail, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': 'jean@email.fr'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.clientTelephone, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.clientTelephone, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': '06 00 00 00 00'}}) }}
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-4 mt-4">
                    <div>
                        {{ form_label(form.clientNumeroRue, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.clientNumeroRue, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': '12'}}) }}
                    </div>
                    <div class="col-span-2">
                        {{ form_label(form.clientNomRue, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.clientNomRue, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': 'Rue de la Paix'}}) }}
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4">
                    <div>
                        {{ form_label(form.clientCodePostal, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.clientCodePostal, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': '75000'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.clientVille, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.clientVille, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': 'Paris'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.clientPays, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.clientPays, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                </div>
            </div>

            <!-- Signature émetteur -->
            <div class="border-b pb-4 mb-2">
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4">Votre signature</h2>
                <p class="text-sm text-gray-500 mb-3">Dessinez votre signature dans le cadre ci-dessous :</p>

                <canvas id="signatureCanvas"
                        class="border-2 border-gray-300 rounded-lg w-full cursor-crosshair bg-white"
                        style="height: 150px; touch-action: none;">
                </canvas>

                <div class="flex gap-3 mt-3">
                    <button type="button" id="clearBtn"
                            class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-300 text-sm">
                        Effacer
                    </button>
                </div>

                <input type="hidden" name="signature_emetteur" id="signatureEmetteurInput">
            </div>

            <!-- Boutons -->
            <div class="grid grid-cols-2 gap-3 pt-4 border-t">
                <a href="{{ path('devis_index') }}" class="text-center bg-gray-200 text-gray-700 px-5 py-3 rounded-lg hover:bg-gray-300 text-sm font-medium">
                    Annuler
                </a>
                <button type="submit" id="submitBtn" class="text-center bg-[#3B0764] text-white px-5 py-3 rounded-lg hover:opacity-90 font-semibold text-sm">
                    Générer le devis
                </button>
            </div>

        {{ form_end(form) }}
    </div>
</div>

<script>
const canvas = document.getElementById('signatureCanvas');
const ctx = canvas.getContext('2d');
let drawing = false;

function resizeCanvas() {
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width;
    canvas.height = rect.height;
    ctx.strokeStyle = '#1a1a1a';
    ctx.lineWidth = 2;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
}
resizeCanvas();

function getPos(e) {
    const rect = canvas.getBoundingClientRect();
    if (e.touches) {
        return { x: e.touches[0].clientX - rect.left, y: e.touches[0].clientY - rect.top };
    }
    return { x: e.clientX - rect.left, y: e.clientY - rect.top };
}

canvas.addEventListener('mousedown', (e) => { drawing = true; ctx.beginPath(); const p = getPos(e); ctx.moveTo(p.x, p.y); });
canvas.addEventListener('mousemove', (e) => { if (!drawing) return; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); });
canvas.addEventListener('mouseup', () => { drawing = false; });
canvas.addEventListener('mouseleave', () => { drawing = false; });
canvas.addEventListener('touchstart', (e) => { e.preventDefault(); drawing = true; ctx.beginPath(); const p = getPos(e); ctx.moveTo(p.x, p.y); });
canvas.addEventListener('touchmove', (e) => { e.preventDefault(); if (!drawing) return; const p = getPos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); });
canvas.addEventListener('touchend', () => { drawing = false; });

document.getElementById('clearBtn').addEventListener('click', () => {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
});

document.getElementById('submitBtn').addEventListener('click', function() {
    const blank = document.createElement('canvas');
    blank.width = canvas.width;
    blank.height = canvas.height;
    const data = canvas.toDataURL('image/png');
    if (data !== blank.toDataURL('image/png')) {
        document.getElementById('signatureEmetteurInput').value = data;
    }
});
</script>
{% endblock %}