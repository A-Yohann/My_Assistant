{% extends 'base.html.twig' %}

{% block title %}Générer un devis{% endblock %}

{% block body %}
{% for message in app.flashes('success') %}
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-2 rounded mb-4">
        {{ message }}
    </div>
{% endfor %}
<div class="container mx-auto max-w-2xl mt-10 bg-white p-8 rounded shadow">
    <h1 class="text-2xl font-bold mb-6">Générer un devis</h1>
    {{ form_start(form) }}
    {{ form_widget(form) }}
    <div class="flex justify-end space-x-2 mt-4">
        <button type="submit" class="bg-[#3B0764] text-white px-6 py-2 rounded">Générer le devis</button>
    </div>
    {{ form_end(form) }}
</div>
{% endblock %}
