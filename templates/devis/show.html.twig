{% extends 'base.html.twig' %}

{% block title %}Détail du devis{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl mt-6 lg:mt-10 bg-white p-4 lg:p-8 rounded shadow mx-4 lg:mx-auto">
    <h1 class="text-xl lg:text-2xl font-bold mb-6">Détail du devis</h1>

    {% for message in app.flashes('success') %}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-2 rounded mb-4">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('info') %}
        <div class="bg-blue-100 border border-blue-400 text-blue-700 px-4 py-2 rounded mb-4">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-2 rounded mb-4">{{ message }}</div>
    {% endfor %}

    <!-- Cards mobile -->
    <div class="md:hidden space-y-2 mb-6">
        <div class="flex justify-between py-2 border-b">
            <span class="text-sm font-semibold text-gray-600">Numéro</span>
            <span class="text-sm">{{ devis.numeroDevis }}</span>
        </div>
        <div class="flex justify-between py-2 border-b">
            <span class="text-sm font-semibold text-gray-600">Date émission</span>
            <span class="text-sm">{{ devis.dateEmission|date('d/m/Y') }}</span>
        </div>
        <div class="flex justify-between py-2 border-b">
            <span class="text-sm font-semibold text-gray-600">Date validité</span>
            <span class="text-sm">{{ devis.dateValidite|date('d/m/Y') }}</span>
        </div>
        <div class="flex justify-between py-2 border-b">
            <span class="text-sm font-semibold text-gray-600">Montant HT</span>
            <span class="text-sm">{{ devis.montantHT }} €</span>
        </div>
        <div class="flex justify-between py-2 border-b">
            <span class="text-sm font-semibold text-gray-600">Montant TTC</span>
            <span class="text-sm font-bold">{{ devis.montantTtc }} €</span>
        </div>
        <div class="flex justify-between py-2 border-b">
            <span class="text-sm font-semibold text-gray-600">Taux TVA</span>
            <span class="text-sm">{{ devis.tauxTVA }}</span>
        </div>
        <div class="flex justify-between py-2 border-b items-center">
            <span class="text-sm font-semibold text-gray-600">Statut</span>
            <span>
                {% if devis.etat == 'en_attente' %}<span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2 py-1 rounded">En attente</span>
                {% elseif devis.etat == 'valide' %}<span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Validé</span>
                {% elseif devis.etat == 'commande' %}<span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2 py-1 rounded">En attente de paiement</span>
                {% elseif devis.etat == 'paye' %}<span class="bg-purple-100 text-purple-800 text-xs font-semibold px-2 py-1 rounded">Payé</span>
                {% else %}<span class="bg-gray-100 text-gray-800 text-xs font-semibold px-2 py-1 rounded">{{ devis.etat }}</span>{% endif %}
            </span>
        </div>
        <div class="flex justify-between py-2 border-b items-center">
            <span class="text-sm font-semibold text-gray-600">Signature</span>
            <span class="text-sm">
                {% if devis.isSignature %}
                    <span class="text-green-600 font-semibold text-xs">✓ Signé le {{ devis.signatureDate|date('d/m/Y') }}</span>
                {% else %}
                    <span class="text-yellow-600 text-xs">En attente</span>
                {% endif %}
            </span>
        </div>
        <div class="py-2 border-b">
            <span class="text-sm font-semibold text-gray-600 block mb-1">Description</span>
            <span class="text-sm text-gray-700">{{ devis.description }}</span>
        </div>
        <div class="flex justify-between py-2 border-b">
            <span class="text-sm font-semibold text-gray-600">Entreprise</span>
            <span class="text-sm">{{ devis.entreprise.nomEntreprise ?? 'N/A' }}</span>
        </div>
    </div>

    <!-- Table desktop -->
    <table class="hidden md:table min-w-full bg-white mb-6">
        <tr class="border-b"><th class="text-left px-4 py-2 w-40">Numéro</th><td class="px-4 py-2">{{ devis.numeroDevis }}</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Date émission</th><td class="px-4 py-2">{{ devis.dateEmission|date('d/m/Y') }}</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Date validité</th><td class="px-4 py-2">{{ devis.dateValidite|date('d/m/Y') }}</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Montant HT</th><td class="px-4 py-2">{{ devis.montantHT }} €</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Montant TTC</th><td class="px-4 py-2">{{ devis.montantTtc }} €</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Taux TVA</th><td class="px-4 py-2">{{ devis.tauxTVA }}</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Statut</th><td class="px-4 py-2">
            {% if devis.etat == 'en_attente' %}<span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2 py-1 rounded">En attente</span>
            {% elseif devis.etat == 'valide' %}<span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Validé</span>
            {% elseif devis.etat == 'commande' %}<span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2 py-1 rounded">En attente de paiement</span>
            {% elseif devis.etat == 'paye' %}<span class="bg-purple-100 text-purple-800 text-xs font-semibold px-2 py-1 rounded">Payé</span>
            {% else %}<span class="bg-gray-100 text-gray-800 text-xs font-semibold px-2 py-1 rounded">{{ devis.etat }}</span>{% endif %}
        </td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Signature</th><td class="px-4 py-2">
            {% if devis.isSignature %}
                <span class="text-green-600 font-semibold">✓ Signé le {{ devis.signatureDate|date('d/m/Y à H:i') }}</span>
            {% else %}
                <span class="text-yellow-600">En attente de signature</span>
            {% endif %}
        </td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Description</th><td class="px-4 py-2">{{ devis.description }}</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Entreprise</th><td class="px-4 py-2">{{ devis.entreprise.nomEntreprise ?? 'N/A' }}</td></tr>
    </table>

    {% if devis.isSignature and devis.signatureImage %}
        <div class="mb-6">
            <p class="text-sm font-semibold text-gray-600 mb-2">Signature électronique :</p>
            <img src="{{ devis.signatureImage }}" alt="Signature" class="border rounded" style="max-height: 100px;">
        </div>
    {% endif %}

    <div class="flex flex-wrap gap-3">
        <a href="{{ path('devis_index') }}" class="bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300 text-sm">
            ← Retour
        </a>
        <a href="{{ path('devis_pdf', {'id': devis.id}) }}" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 text-sm">
            Télécharger PDF
        </a>
        <a href="{{ path('devis_envoyer', {'id': devis.id}) }}" class="bg-[#3B0764] text-white px-4 py-2 rounded hover:opacity-90 text-sm">
            Envoyer par mail
        </a>
    </div>
</div>
{% endblock %}