{% extends 'base.html.twig' %}

{% block body %}
    <h1 class="mb-6">Informations de l'entreprise</h1>
    <div class="p-6 border rounded bg-gray-50 mb-6">
        <strong class="text-lg">Nom :</strong> {{ entreprise.nomEntreprise }}<br>
        <strong>SIRET :</strong> {{ entreprise.siret }}<br>
        <strong>Forme juridique :</strong> {{ entreprise.formeJuridique }}<br>
        <strong>Statut :</strong> {{ entreprise.status }}<br>
        <strong>Date de création :</strong> {{ entreprise.dateCreation|date('d/m/Y') }}<br>
        <strong>Téléphone :</strong> {{ entreprise.telephone }}<br>
        <strong>Email :</strong> {{ entreprise.email }}<br>
        <strong>Logo :</strong> <br>
        {% if entreprise.logo %}
            <img src="{{ entreprise.logo }}" alt="Logo" class="w-32 h-32 object-contain mb-4">
        {% else %}
            <span>Aucun logo</span>
        {% endif %}
        <hr class="my-4">
        <strong>Adresse :</strong><br>
        {{ entreprise.numeroRue }} {{ entreprise.nomRue }}<br>
        {% if entreprise.complementAdresse %}
            {{ entreprise.complementAdresse }}<br>
        {% endif %}
        {{ entreprise.codePostal }} {{ entreprise.ville }}<br>
        {{ entreprise.pays }}
    </div>
    <div class="flex gap-4 mt-4">
        <a href="{{ path('entreprise_edit', {'id': entreprise.id}) }}" class="bg-blue-600 text-white px-4 py-2 rounded">Modifier</a>
        <a href="{{ path('entreprise_delete', {'id': entreprise.id}) }}" class="bg-red-600 text-white px-4 py-2 rounded">Supprimer</a>
        <a href="{{ path('app_entreprise') }}" class="bg-gray-600 text-white px-4 py-2 rounded">Retour</a>
    </div>
{% endblock %}
