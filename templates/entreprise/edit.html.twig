{% extends 'base.html.twig' %}

{% block title %}Modifier l'entreprise{% endblock %}

{% block body %}
<div class="container mx-auto max-w-2xl mt-6 lg:mt-10 px-4 mb-10">
    <div class="bg-white rounded-xl shadow p-6 lg:p-8">
        <h1 class="text-2xl font-bold mb-8 text-[#231F20]">Modifier l'entreprise</h1>

        {{ form_start(form, {'attr': {'class': 'space-y-5', 'enctype': 'multipart/form-data'}}) }}

            <div class="border-b pb-4 mb-2">
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4">Informations générales</h2>

                <div>
                    {{ form_label(form.nomEntreprise, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.nomEntreprise, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                    <div>
                        {{ form_label(form.siret, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.siret, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.email, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                    <div>
                        {{ form_label(form.formeJuridique, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.formeJuridique, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.status, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.status, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                    <div>
                        {{ form_label(form.telephone, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.telephone, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.dateCreation, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.dateCreation, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                </div>
            </div>

            <div class="border-b pb-4 mb-2">
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4">Adresse</h2>

                <div class="grid grid-cols-3 gap-4">
                    <div>
                        {{ form_label(form.numeroRue, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.numeroRue, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                    <div class="col-span-2">
                        {{ form_label(form.nomRue, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.nomRue, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                </div>

                <div class="mt-4">
                    {{ form_label(form.complementAdresse, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.complementAdresse, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-4">
                    <div>
                        {{ form_label(form.codePostal, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.codePostal, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.ville, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.ville, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.pays, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.pays, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                </div>
            </div>

            <div>
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4">Logo</h2>
                <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 bg-gray-50 hover:bg-gray-100 transition cursor-pointer">
                    {{ form_widget(form.logo) }}
                    <p class="text-xs text-gray-400 mt-1 text-center">PNG, JPG acceptés</p>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3 pt-4 border-t">
                <a href="{{ path('app_entreprise') }}" class="text-center bg-gray-200 text-gray-700 px-5 py-3 rounded-lg hover:bg-gray-300 text-sm font-medium">
                    Annuler
                </a>
                {{ form_widget(form.save, {'attr': {'class': 'w-full bg-[#3B0764] text-white px-5 py-3 rounded-lg hover:opacity-90 font-semibold text-sm'}}) }}
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}