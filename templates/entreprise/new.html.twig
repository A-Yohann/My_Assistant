{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-2xl mx-auto mt-10 px-4 mb-10">
    <h1 class="text-3xl font-bold text-center mb-8 text-[#231F20]">
        Créer une entreprise
    </h1>

    {# ✅ Affichage des erreurs globales #}
{% if not form.vars.valid %}
    <div class="bg-red-100 text-red-800 p-4 rounded mb-6">
        <strong>Erreur :</strong> Votre formulaire n'est pas conforme aux attentes.
        <ul class="mt-2 list-disc list-inside">
            {{ form_errors(form) }}
        </ul>
    </div>
{% endif %}

    <div class="bg-white rounded-xl shadow p-8">
        {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}

            <div>
                {{ form_label(form.nomEntreprise, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.nomEntreprise, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
               <div class="text-red-600 text-sm mt-1">

                {{ form_errors(form.nomEntreprise) }}
                </div>
            </div>

            <div>
                {{ form_label(form.siret, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.siret, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                              <div class="text-red-600 text-sm mt-1">

                {{ form_errors(form.siret) }}
                              </div>
            </div>

            <div>
                {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.email, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}

                <div class="text-red-600 text-sm mt-1">
                    {{ form_errors(form.email) }}
                </div>
            </div>

            <div>
                {{ form_label(form.dateCreation, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.dateCreation, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}

                <div class="text-red-600 text-sm mt-1">
                    {{ form_errors(form.dateCreation) }}
                </div>
            </div>

            <div>
            {% if logo_temp %}
                <div class="mb-2">
                    <p class="text-xs text-gray-500 mb-1">Logo actuel :</p>
                    <img src="{{ logo_temp }}" alt="Logo" class="w-16 h-16 object-contain rounded border">
                </div>
            {% endif %}
                {{ form_label(form.logo, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 bg-gray-50 hover:bg-gray-100 transition cursor-pointer">
                    {{ form_widget(form.logo) }}
                    <p class="text-xs text-gray-400 mt-1 text-center">
                        PNG, JPG acceptés
                    </p>
                </div>
                <div class="text-red-600 text-sm mt-1">
                    {{ form_errors(form.logo) }}
                </div>
            </div>

            <div>
                {{ form_label(form.formeJuridique, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.formeJuridique, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}

                <div class="text-red-600 text-sm mt-1">
                    {{ form_errors(form.formeJuridique) }}
                </div>
            </div>

            <div>
                {{ form_label(form.status, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.status, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                <div class="text-red-600 text-sm mt-1">
                    {{ form_errors(form.status) }}
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.numeroRue, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.numeroRue, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2'}}) }}
                    <div class="text-red-600 text-sm mt-1">
                        {{ form_errors(form.numeroRue) }}
                    </div>
                </div>
                <div>
                    {{ form_label(form.nomRue, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.nomRue, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2'}}) }}
                    <div class="text-red-600 text-sm mt-1">
                        {{ form_errors(form.nomRue) }}
                    </div>
                </div>
            </div>

            <div>
                {{ form_label(form.complementAdresse, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.complementAdresse, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2'}}) }}
                <div class="text-red-600 text-sm mt-1">
                    {{ form_errors(form.complementAdresse) }}
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.codePostal, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.codePostal, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2'}}) }}
                    <div class="text-red-600 text-sm mt-1">
                        {{ form_errors(form.codePostal) }}
                    </div>
                </div>
                <div>
                    {{ form_label(form.ville, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.ville, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2'}}) }}
                    <div class="text-red-600 text-sm mt-1">
                        {{ form_errors(form.ville) }}
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.pays, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.pays, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2'}}) }}
                    <div class="text-red-600 text-sm mt-1">
                        {{ form_errors(form.pays) }}
                    </div>
                </div>
                <div>
                    {{ form_label(form.telephone, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.telephone, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2'}}) }}
                    <div class="text-red-600 text-sm mt-1">
                        {{ form_errors(form.telephone) }}
                    </div>
                </div>
            </div>

            <!-- Siège social (optionnel) -->
            <div class="border-t pt-4 mt-4">
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wide mb-4">
                    Siège social <span class="text-xs text-gray-300">(optionnel)</span>
                </h2>

                <div>
                    {{ form_label(form.siege.nomSiege, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.siege.nomSiege, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': 'Ex: Siège Paris'}}) }}
                </div>

                <div class="mt-4">
                    {{ form_label(form.siege.addresseSiege, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.siege.addresseSiege, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': 'Ex: 12 rue de la Paix, 75000 Paris'}}) }}
                </div>

                <div class="mt-4">
                    {{ form_label(form.siege.dateCreation, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.siege.dateCreation, {'attr': {'class': 'block w-full border border-gray-300 rounded p-2 focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                </div>

                <div class="flex items-center gap-3 mt-4 p-3 bg-gray-50 rounded-lg border border-gray-200">
                    {{ form_widget(form.siege.statuJuridique, {'attr': {'class': 'w-4 h-4 accent-[#3B0764]'}}) }}
                    {{ form_label(form.siege.statuJuridique, null, {'label_attr': {'class': 'text-sm font-medium text-gray-700 cursor-pointer'}}) }}
                </div>
            </div>

            <div class="flex justify-end gap-3 mt-6">
                <a href="{{ path('app_entreprise') }}" class="bg-gray-200 text-gray-700 px-6 py-2 rounded hover:bg-gray-300">
                    Annuler
                </a>
                <button type="submit" class="bg-[#3B0764] text-white px-6 py-2 rounded hover:opacity-90">
                    Valider
                </button>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
