{% extends 'base.html.twig' %}

{% block body %}
    <h1 class="mb-6">Mes entreprises</h1>
    <a href="{{ path('entreprise_new') }}" class="bg-blue-500 text-white px-4 py-2 rounded mb-6 block">Créer une entreprise</a>
    <ul class="mt-6">
        {% for entreprise in entreprises %}
            <li class="mb-6 p-4 border rounded bg-gray-50">
                <a href="{{ path('entreprise_show', {'idEntreprise': entreprise.idEntreprise}) }}" class="text-lg font-bold text-blue-700 hover:underline">
                    {{ entreprise.nomEntreprise }}
                </a>
                <span class="text-gray-600">({{ entreprise.siret }})</span><br>
                <div class="mt-2">
                    <a href="{{ path('entreprise_edit', {'id': entreprise.idEntreprise}) }}" class="text-blue-600 mr-4">Modifier</a>
                    <a href="{{ path('entreprise_delete', {'id': entreprise.idEntreprise}) }}" class="text-red-600">Supprimer</a>
                </div>
            </li>
        {% else %}
            <li>Aucune entreprise créée.</li>
        {% endfor %}
    </ul>
{% endblock %}
