{% extends 'base.html.twig' %}
{% block title %}Entreprise{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto mt-10 px-4">
    <h1 class="mb-6 text-center font-bold text-3xl">Mes entreprises</h1>

    <div class="flex justify-center mb-6">
        <a href="{{ path('entreprise_new') }}"
           class="bg-[#3B0764] text-white px-4 py-2 rounded text-sm font-semibold hover:bg-[#4C0D8A] transition">
            Créer une entreprise
        </a>
    </div>

    <div class="space-y-4">
        {% for entreprise in entreprises %}
            <div class="p-4 border rounded bg-gray-50 flex flex-col gap-4">

                <div class="flex items-center gap-4">
                    <img src="{{ entreprise.logo }}"
                         class="h-16 w-16 rounded-full object-cover">

                    <div class="flex-1">
                        <a href="{{ path('entreprise_show', {'id': entreprise.id}) }}"
                           class="text-lg font-bold text-blue-700 hover:underline">
                            {{ entreprise.nomEntreprise }}
                        </a>
                        <div class="text-gray-600">({{ entreprise.siret }})</div>
                    </div>
                </div>

                <div class="flex justify-end gap-4">
                    <a href="{{ path('entreprise_edit', {'id': entreprise.id}) }}"
                       class="text-blue-600 hover:underline text-sm">
                        Modifier
                    </a>

                    <!-- BOUTON MODAL -->
                    <button type="button"
                        class="text-red-600 hover:underline text-sm"
                        onclick="document.getElementById('confirmModal-{{ entreprise.id }}').classList.remove('hidden')">
                        Supprimer
                    </button>
                </div>
            </div>

            {# MODAL (UNE PAR ENTREPRISE) #}
            <div id="confirmModal-{{ entreprise.id }}"
                 class="hidden fixed inset-0 flex items-center justify-center bg-black bg-opacity-50">

                <div class="bg-white p-6 rounded shadow w-96">
                    <p class="mb-4 text-center">
                        Supprimer l’entreprise <strong>{{ entreprise.nomEntreprise }}</strong> ?
                    </p>

                    <form method="post"
                          action="{{ path('entreprise_delete', {'id': entreprise.id}) }}">

                        <div class="flex gap-4">
                            <button type="submit"
                                    class="bg-red-500 text-white px-4 py-2 rounded w-full">
                                Oui, supprimer
                            </button>

                            <button type="button"
                                    class="bg-gray-300 px-4 py-2 rounded w-full"
                                    onclick="document.getElementById('confirmModal-{{ entreprise.id }}').classList.add('hidden')">
                                Annuler
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        {% else %}
            <p class="text-center text-gray-500">Aucune entreprise créée.</p>
        {% endfor %}
    </div>
</div>
{% endblock %}
