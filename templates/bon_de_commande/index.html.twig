{% extends 'base.html.twig' %}

{% block title %}Liste des bons de commande{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl mt-10 bg-white p-8 rounded shadow">
    <h1 class="text-2xl font-bold mb-6">Liste des bons de commande</h1>
    <table class="min-w-full bg-white">
        <thead>
            <tr>
                <th class="px-4 py-2">Numéro</th>
                <th class="px-4 py-2">Date création</th>
                <th class="px-4 py-2">Montant HT</th>
                <th class="px-4 py-2">Montant TTC</th>
                <th class="px-4 py-2">Statut</th>
                <th class="px-4 py-2">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for bon in bons %}
                <tr class="border-b">
                    <td class="px-4 py-2">{{ bon.numeroBon }}</td>
                    <td class="px-4 py-2">{{ bon.dateCreation|date('d/m/Y') }}</td>
                    <td class="px-4 py-2">{{ bon.montantHT }} €</td>
                    <td class="px-4 py-2">{{ bon.montantTtc }} €</td>
                    <td class="px-4 py-2">
                        {% if bon.etat == 'en_attente' %}
                            <span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2 py-1 rounded">En attente</span>
                        {% elseif bon.etat == 'paye' %}
                            <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Payé</span>
                        {% endif %}
                    </td>
                    <td class="px-4 py-2">
                        <a href="{{ path('bon_de_commande_show', {'id': bon.id}) }}" class="text-blue-600 hover:underline">Voir</a>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center py-4">Aucun bon de commande trouvé.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}