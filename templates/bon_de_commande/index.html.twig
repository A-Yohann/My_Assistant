{% extends 'base.html.twig' %}

{% block title %}Liste des bons de commande{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl mt-6 lg:mt-10 bg-white p-4 lg:p-8 rounded shadow mx-4 lg:mx-auto">

    <h1 class="text-xl lg:text-2xl font-bold mb-6">Liste des bons de commande</h1>

    <!-- Table (masquée sur mobile) -->
    <div class="hidden md:block overflow-x-auto">
        <table class="min-w-full bg-white">
            <thead>
                <tr class="bg-[#3B0764] text-white">
                    <th class="px-4 py-2 text-left">Numéro</th>
                    <th class="px-4 py-2 text-left">Date création</th>
                    <th class="px-4 py-2 text-left">Montant HT</th>
                    <th class="px-4 py-2 text-left">Montant TTC</th>
                    <th class="px-4 py-2 text-left">Statut</th>
                    <th class="px-4 py-2 text-left">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for bon in bons %}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="px-4 py-2 font-medium">{{ bon.numeroBon }}</td>
                        <td class="px-4 py-2">{{ bon.dateCreation|date('d/m/Y') }}</td>
                        <td class="px-4 py-2">{{ bon.montantHT }} €</td>
                        <td class="px-4 py-2">{{ bon.montantTtc }} €</td>
                        <td class="px-4 py-2">
                            {% if bon.etat == 'en_attente' %}
                                <span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2 py-1 rounded">En attente</span>
                            {% elseif bon.etat == 'paye' %}
                                <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Payé</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-2">
                            <a href="{{ path('bon_de_commande_show', {'id': bon.id}) }}" class="text-blue-600 hover:underline text-sm">Voir</a>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="text-center py-4 text-gray-400">Aucun bon de commande trouvé.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Cards mobile -->
    <div class="md:hidden space-y-3">
        {% for bon in bons %}
            <div class="border rounded-lg p-4 bg-gray-50">
                <div class="flex justify-between items-start mb-2">
                    <span class="font-bold text-[#231F20]">{{ bon.numeroBon }}</span>
                    {% if bon.etat == 'en_attente' %}
                        <span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2 py-1 rounded">En attente</span>
                    {% elseif bon.etat == 'paye' %}
                        <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Payé</span>
                    {% endif %}
                </div>
                <div class="text-sm text-gray-600 mb-1">📅 {{ bon.dateCreation|date('d/m/Y') }}</div>
                <div class="text-sm text-gray-600 mb-1">HT : <span class="font-medium">{{ bon.montantHT }} €</span></div>
                <div class="text-sm text-gray-600 mb-3">TTC : <span class="font-medium">{{ bon.montantTtc }} €</span></div>
                <a href="{{ path('bon_de_commande_show', {'id': bon.id}) }}"
                   class="block text-center bg-[#3B0764] text-white text-sm px-4 py-2 rounded hover:opacity-90">
                    Voir le bon de commande
                </a>
            </div>
        {% else %}
            <p class="text-center text-gray-400 py-4">Aucun bon de commande trouvé.</p>
        {% endfor %}
    </div>
</div>
<!-- Pagination -->
<div class="flex justify-center mt-6">
    {{ knp_pagination_render(bons) }}
</div>
{% endblock %}