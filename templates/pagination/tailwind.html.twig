{% if pageCount > 1 %}
<div class="flex justify-center items-center gap-2 mt-6 pb-6">

    {% if current > 1 %}
        <a href="{{ path(route, query|merge({(pageParameterName): current - 1})) }}"
           class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm text-gray-700 hover:bg-[#3B0764] hover:text-white transition">
            ← Précédent
        </a>
    {% else %}
        <span class="px-3 py-2 bg-gray-100 border border-gray-200 rounded-lg text-sm text-gray-400 cursor-not-allowed">
            ← Précédent
        </span>
    {% endif %}

    {% for page in pagesInRange %}
        {% if page == current %}
            <span class="px-3 py-2 bg-[#3B0764] text-white rounded-lg text-sm font-bold">
                {{ page }}
            </span>
        {% else %}
            <a href="{{ path(route, query|merge({(pageParameterName): page})) }}"
               class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm text-gray-700 hover:bg-[#3B0764] hover:text-white transition">
                {{ page }}
            </a>
        {% endif %}
    {% endfor %}

    {% if current < pageCount %}
        <a href="{{ path(route, query|merge({(pageParameterName): current + 1})) }}"
           class="px-3 py-2 bg-white border border-gray-300 rounded-lg text-sm text-gray-700 hover:bg-[#3B0764] hover:text-white transition">
            Suivant →
        </a>
    {% else %}
        <span class="px-3 py-2 bg-gray-100 border border-gray-200 rounded-lg text-sm text-gray-400 cursor-not-allowed">
            Suivant →
        </span>
    {% endif %}

</div>
{% endif %}