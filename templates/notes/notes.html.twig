{% extends 'base.html.twig' %}

{% block title %}Notes{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col items-center justify-center bg-[#f2f2f2]">
    <h1 class="text-4xl font-bold mb-8">Gestion des notes</h1>
    <div class="w-full max-w-3xl bg-white rounded-lg shadow p-8 mb-6">
        <a href="{{ path('note_new') }}" class="bg-[#3B0764] text-white px-4 py-2 rounded mb-4 inline-block">Ajouter une note</a>
        <table class="min-w-full mt-4">
            <thead>
                <tr>
                    <th class="px-4 py-2">Titre</th>
                    <th class="px-4 py-2">Contenu</th>
                    <th class="px-4 py-2">Priorité</th>
                    <th class="px-4 py-2">Créée le</th>
                    <th class="px-4 py-2">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for note in notes %}
                    <tr class="border-b">
                        <td class="px-4 py-2">{{ note.titre }}</td>
                        <td class="px-4 py-2">{{ note.contenu|u.truncate(40) }}</td>
                        <td class="px-4 py-2">{{ note.priorite ? 'Oui' : 'Non' }}</td>
                        <td class="px-4 py-2">{{ note.dateCreation ? note.dateCreation|date('d/m/Y H:i') : '' }}</td>
                        <td class="px-4 py-2">
                            <a href="{{ path('note_edit', {'idNote': note.idNote}) }}" class="text-blue-600 hover:underline mr-2">Modifier</a>
                            <form method="post" action="{{ path('note_delete', {'idNote': note.idNote}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette note ?');">
                                <button type="submit" class="text-red-600 hover:underline bg-transparent border-none p-0">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="text-center py-4">Aucune note trouvée.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
