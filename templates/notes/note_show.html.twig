{% extends 'base.html.twig' %}

{% block title %}{{ note.titre }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-[#f2f2f2] p-6">
    <div class="max-w-2xl mx-auto bg-white rounded-xl shadow p-8">

        <div class="flex justify-between items-start mb-6">
            <h1 class="text-2xl font-bold text-[#231F20]">{{ note.titre }}</h1>
            {% if note.priorite %}
                <span class="bg-red-100 text-red-800 text-xs font-semibold px-3 py-1 rounded">Urgent</span>
            {% else %}
                <span class="bg-gray-100 text-gray-600 text-xs font-semibold px-3 py-1 rounded">Normal</span>
            {% endif %}
        </div>

        <p class="text-gray-700 mb-6 whitespace-pre-line">{{ note.contenu }}</p>

        <p class="text-sm text-gray-400 mb-6">
            Créée le {{ note.dateCreation ? note.dateCreation|date('d/m/Y à H:i') : '' }}
        </p>

        <div class="flex gap-3">
            <a href="{{ path('notes') }}" class="bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300">
                ← Retour
            </a>
            <a href="{{ path('note_edit', {'idNote': note.idNote}) }}"
               class="bg-[#3B0764] text-white px-4 py-2 rounded hover:opacity-90">
                Modifier
            </a>
            <form method="post" action="{{ path('note_delete', {'idNote': note.idNote}) }}"
                  onsubmit="return confirm('Supprimer cette note ?');">
                <button type="submit" class="bg-red-600 text-white px-4 py-2 rounded hover:opacity-90">
                    Supprimer
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}