{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
<div class="flex min-h-screen bg-[#f2f2f2]">
    <!-- Sidebar -->
<aside class="w-48 bg-[#231F20] text-white flex flex-col py-8 rounded-r-lg rounded-br-lg shadow-lg h-[90vh] mt-8 ml-0">
    <nav class="flex-1 space-y-4 px-4">
        <a href="/dashboard" class="block py-2 px-4 rounded hover:bg-gray-700">Tableau de bord</a>
        <a href="{{ path('devis_index') }}" class="block py-2 px-4 rounded hover:bg-gray-700">Devis</a>
        <a href="{{ path('bon_de_commande_index') }}" class="block py-2 px-4 rounded hover:bg-gray-700">Bons de commande</a>
        <a href="{{ path('facture_index') }}" class="block py-2 px-4 rounded hover:bg-gray-700">Factures</a>
        <a href="{{ path('client_index') }}" class="block py-2 px-4 rounded hover:bg-gray-700">Clients</a>
        <a href="{{ path('depense_index') }}" class="block py-2 px-4 rounded hover:bg-gray-700">Dépenses</a>
        <a href="{{ path('notes') }}" class="block py-2 px-4 rounded hover:bg-gray-700">Notes</a>
    </nav>

    <!-- ✅ Sélecteur d'entreprise active -->
    {% if entreprises|length > 1 %}
        <div class="px-4 pb-4">
            <div class="text-xs text-gray-400 mb-2">Entreprise active :</div>
            <div class="text-xs font-semibold text-white mb-2 truncate">
                {{ entreprise ? entreprise.nomEntreprise : 'Aucune' }}
            </div>
            <div class="space-y-1">
                {% for e in entreprises %}
                    {% if e.id != (entreprise ? entreprise.id : 0) %}
                        <a href="{{ path('entreprise_switcher', {'id': e.id}) }}"
                           class="block text-xs bg-gray-700 hover:bg-gray-600 px-2 py-1 rounded truncate">
                            → {{ e.nomEntreprise }}
                        </a>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    {% endif %}
</aside>

    <!-- Main content -->
    <main class="flex-1 p-8">
        <!-- Profil -->
        <div class="flex justify-center mb-6">
            <div class="flex items-center bg-[#231F20] text-white rounded-lg px-8 py-4">
                <img src="{{ user and user.avatar ? user.avatar : '/assets/img/logo.png' }}" alt="Avatar" class="h-16 w-16 rounded-full mr-4">
                <div>
                    <div class="font-bold text-lg">
                        {% if user and user.nom is defined and user.prenom is defined %}
                            {{ user.nom }} {{ user.prenom }}
                        {% elseif user %}
                            {{ user.getUserIdentifier() }}
                        {% else %}
                            Invité
                        {% endif %}
                    </div>
                    <div class="text-sm">{{ user.email }}</div>
                    {% if entreprise %}
                        <div class="text-xs mt-1">{{ entreprise.nomEntreprise }}</div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Cards -->
        <div class="grid grid-cols-3 gap-6 mb-6">
            <a href="{{ path('devis_index') }}" class="bg-[#3B0764] text-white rounded p-6 text-center hover:opacity-90">
                <div class="font-bold mb-2">Devis en attente</div>
                <div class="text-3xl">{{ devisEnAttente }}</div>
            </a>
            <a href="{{ path('facture_index') }}" class="bg-[#3B0764] text-white rounded p-6 text-center hover:opacity-90">
                <div class="font-bold mb-2">Factures</div>
                <div class="text-3xl">{{ totalFactures }}</div>
            </a>
            <a href="{{ path('bon_de_commande_index') }}" class="bg-[#3B0764] text-white rounded p-6 text-center hover:opacity-90">
                <div class="font-bold mb-2">Bons de commande</div>
                <div class="text-3xl">→</div>
            </a>
        </div>

        <div class="flex justify-center mb-8">
            <a href="{{ path('devis_generer') }}" class="bg-[#231F20] text-white px-6 py-2 rounded block text-center">Générer le devis</a>
        </div>

        <!-- Devis récent & Notes -->
        <div class="grid grid-cols-3 gap-6 mb-8">
            <div class="col-span-2">
                <div class="font-bold text-lg mb-2">Devis récent</div>
                <div class="bg-[#3B0764] text-white rounded p-6 mb-6">
                    <table class="w-full text-left">
                        <thead>
                            <tr>
                                <th>Client</th>
                                <th>Montant</th>
                                <th>Statut</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% if lastDevis is not empty %}
                            {% for devis in lastDevis %}
                                <tr>
                                    <td>{{ devis.client ? devis.client.nom ~ ' ' ~ devis.client.prenom : (devis.entreprise ? devis.entreprise.nomEntreprise : '') }}</td>
                                    <td>{{ devis.montantTtc|number_format(2, ',', ' ') }}€</td>
                                    <td>
                                        {% if devis.etat == 'valide' %}
                                            Validé
                                        {% elseif devis.etat == 'en_attente' %}
                                            En attente
                                        {% elseif devis.etat == 'paye' %}
                                            Payé
                                        {% else %}
                                            {{ devis.etat }}
                                        {% endif %}
                                    </td>
                                    <td>{{ devis.dateCreation ? devis.dateCreation|date('d/m/y') : '' }}</td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center">Aucun devis récent.</td>
                            </tr>
                        {% endif %}
                        </tbody>
                    </table>
                </div>

                <!-- Activité récente = dernières dépenses -->
                <div>
                    <div class="font-bold mb-2">Activité récente</div>
                    <div class="space-y-2">
                        {% if lastDepenses is not empty %}
                            {% for depense in lastDepenses %}
                                <div class="bg-[#3B0764] text-white rounded p-3 flex justify-between">
                                    <span>{{ depense.libelle }}</span>
                                    <span>{{ depense.dateDepense|date('d/m/y') }}</span>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="bg-[#3B0764] text-white rounded p-3 text-center text-sm">
                                Aucune dépense récente.
                            </div>
                        {% endif %}
                    </div>
                    <div class="mt-2 text-right">
                        <a href="{{ path('depense_index') }}" class="text-sm text-[#3B0764] hover:underline">Voir toutes les dépenses →</a>
                    </div>
                </div>
            </div>

            <div>
                <div class="bg-[#3B0764] text-white rounded p-6 mb-6">
                    <div class="flex justify-between items-center mb-2">
                        <span class="font-bold">Vos notes</span>
                        <a href="{{ path('notes') }}" class="bg-black text-white px-2 py-1 rounded text-xs">Voir toutes</a>
                    </div>
                    {% if lastNotes is not empty %}
                        {% for note in lastNotes %}
                            <div class="mb-2 bg-white text-black rounded p-2">
                                <div class="font-bold text-xs">{{ note.titre }}</div>
                                <div>{{ note.contenu|u.truncate(40) }}</div>
                                <div class="text-xs text-right">Note mise le {{ note.dateCreation ? note.dateCreation|date('d/m/y') : '' }}</div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="text-xs">Aucune note récente.</div>
                    {% endif %}
                </div>

                <div class="bg-[#3B0764] text-white rounded p-6">
                    <div class="flex justify-between items-center mb-2">
                        <span class="font-bold">Clients récents</span>
                        <a href="{{ path('client_index') }}" class="text-xs underline">voir plus</a>
                    </div>
                    <ul class="space-y-1">
                        {% if lastClients is not empty %}
                            {% for client in lastClients %}
                                <li>
                                    <a href="{{ path('client_show', {'id': client.idClient}) }}" class="hover:underline">
                                        {{ client.nom }} {{ client.prenom }}
                                    </a>
                                </li>
                            {% endfor %}
                        {% else %}
                            <li class="text-xs">Aucun client récent.</li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}