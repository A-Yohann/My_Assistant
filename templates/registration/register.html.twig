{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
<div class="flex justify-center py-12 px-4">
    <div class="bg-[#3B0764] text-[#f2F2F2] rounded-xl shadow-xl max-w-md w-full p-10 space-y-6">

        <h1 class="text-3xl font-bold text-center">Créer un compte</h1>

        {% for flash_error in app.flashes('verify_email_error') %}
            <div class="bg-red-500 text-white p-3 rounded">
                {{ flash_error }}
            </div>
        {% endfor %}

        {{ form_start(registrationForm) }}

        {# EMAIL #}
        <div>
            {{ form_label(registrationForm.email, null, {'label_attr': {'class': 'block mb-1 font-semibold'}}) }}
            {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full border border-gray-300 text-white p-2 rounded'}}) }}
            {{ form_errors(registrationForm.email) }}
        </div>

        {# PASSWORD #}
        <div>
            {{ form_label(registrationForm.plainPassword.first, 'Mot de passe', {'label_attr': {'class': 'block mb-1 font-semibold'}}) }}
            <div class="relative">
                {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'w-full border border-gray-300 text-white p-2 rounded pr-10'}}) }}
                <button type="button" onclick="togglePassword(this)"
                        class="absolute right-2 top-2 text-gray-300 hover:text-white">
                    👁
                </button>
            </div>

            <div id="password-rules" class="text-sm mt-2 space-y-1">
                <p id="rule-length" class="text-red-300">✗ Au moins 8 caractères</p>
                <p id="rule-uppercase" class="text-red-300">✗ Une majuscule</p>
                <p id="rule-lowercase" class="text-red-300">✗ Une minuscule</p>
                <p id="rule-number" class="text-red-300">✗ Un chiffre</p>
                <p id="rule-special" class="text-red-300">✗ Un caractère spécial</p>
                <p id="rule-match" class="text-red-300">✗ Les mots de passe correspondent</p>
            </div>

            {{ form_errors(registrationForm.plainPassword.first) }}
        </div>

        {# CONFIRM PASSWORD #}
        <div>
            {{ form_label(registrationForm.plainPassword.second, 'Confirmer le mot de passe', {'label_attr': {'class': 'block mb-1 font-semibold'}}) }}
            <div class="relative">
                {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'w-full border border-gray-300 text-white p-2 rounded pr-10'}}) }}
                <button type="button" onclick="togglePassword(this)"
                        class="absolute right-2 top-2 text-gray-300 hover:text-white">
                    👁
                </button>
            </div>
            {{ form_errors(registrationForm.plainPassword.second) }}
        </div>

        {# TERMS #}
        <div class="flex items-center gap-2">
            {{ form_widget(registrationForm.agreeTerms) }}
            {{ form_label(registrationForm.agreeTerms, null, {'label_attr': {'class': 'text-sm'}}) }}
            {{ form_errors(registrationForm.agreeTerms) }}
        </div>

        <button type="submit" class="w-full bg-white text-[#3B0764] font-semibold py-2 rounded hover:bg-gray-100 transition">
            S'inscrire
        </button>

        <div class="text-center text-sm">
            <span>Déjà inscrit ?</span>
            <a href="{{ path('app_login') }}" class="underline font-semibold hover:text-gray-200">
                Cliquez ici
            </a>
        </div>

        {{ form_end(registrationForm) }}

    </div>
</div>

<script>
function togglePassword(btn) {
    const input = btn.previousElementSibling;
    if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = '🙈';
    } else {
        input.type = 'password';
        btn.textContent = '👁';
    }
}

document.addEventListener("DOMContentLoaded", function () {
    const password = document.querySelector('input[name$="[first]"]');
    const confirm  = document.querySelector('input[name$="[second]"]');

    const rules = {
        length:  document.getElementById('rule-length'),
        upper:   document.getElementById('rule-uppercase'),
        lower:   document.getElementById('rule-lowercase'),
        number:  document.getElementById('rule-number'),
        special: document.getElementById('rule-special'),
        match:   document.getElementById('rule-match')
    };

    function updateRules() {
        const value        = password.value;
        const confirmValue = confirm.value;

        updateRule(rules.length,  value.length >= 8);
        updateRule(rules.upper,   /[A-Z]/.test(value));
        updateRule(rules.lower,   /[a-z]/.test(value));
        updateRule(rules.number,  /[0-9]/.test(value));
        updateRule(rules.special, /[^A-Za-z0-9]/.test(value));
        updateRule(rules.match,   value.length > 0 && value === confirmValue);
    }

    function updateRule(element, isValid) {
        if (!element) return;
        const text = element.textContent.slice(2);
        element.classList.remove('text-red-300', 'text-green-300');
        element.classList.add(isValid ? 'text-green-300' : 'text-red-300');
        element.textContent = (isValid ? '✓ ' : '✗ ') + text;
    }

    password.addEventListener('input', updateRules);
    confirm.addEventListener('input', updateRules);
});
</script>

{% endblock %}