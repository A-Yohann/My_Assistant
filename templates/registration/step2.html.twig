{% extends 'base.html.twig' %}

{% block title %}Inscription — Étape 2{% endblock %}

{% block body %}
<div class="flex justify-center py-12 px-4">
    <div class="bg-[#3B0764] text-white rounded-xl shadow-xl max-w-md w-full p-10 space-y-6">

        <div class="text-center">
            <h1 class="text-3xl font-bold mb-2">Finaliser l'inscription</h1>
            <p class="text-sm text-white/70">Étape 2 sur 2 — Vos informations</p>
            <div class="flex gap-2 justify-center mt-3">
                <div class="h-2 w-16 bg-white/30 rounded-full"></div>
                <div class="h-2 w-16 bg-white rounded-full"></div>
            </div>
        </div>

        

        <div class="bg-white/10 rounded-lg p-3 text-sm text-center">
            📧 Inscription pour <strong>{{ email }}</strong>
        </div>

        <form method="post" class="space-y-4">
            <input type="hidden" name="token" value="{{ token }}">

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block mb-1 font-semibold text-sm">Nom <span class="text-red-300">*</span></label>
                    <input type="text" name="nom"
                           class="w-full border border-gray-300 text-white bg-white/10 p-2 rounded focus:outline-none focus:ring-2 focus:ring-white"
                           placeholder="Dupond" required>
                </div>
                <div>
                    <label class="block mb-1 font-semibold text-sm">Prénom <span class="text-red-300">*</span></label>
                    <input type="text" name="prenom"
                           class="w-full border border-gray-300 text-white bg-white/10 p-2 rounded focus:outline-none focus:ring-2 focus:ring-white"
                           placeholder="Jean" required>
                </div>
            </div>

            <div>
                <label class="block mb-1 font-semibold text-sm">Téléphone</label>
                <input type="tel" name="telephone"
                       class="w-full border border-gray-300 text-white bg-white/10 p-2 rounded focus:outline-none focus:ring-2 focus:ring-white"
                       placeholder="06 00 00 00 00">
            </div>

            <div>
                <label class="block mb-1 font-semibold text-sm">Mot de passe <span class="text-red-300">*</span></label>
                <div class="relative">
                    <input type="password" name="password" id="password"
                           class="w-full border border-gray-300 text-white bg-white/10 p-2 rounded pr-10 focus:outline-none focus:ring-2 focus:ring-white"
                           placeholder="••••••••" required>
                    <button type="button" onclick="togglePassword(this)"
                            class="absolute right-2 top-2 text-white/70 hover:text-white">👁</button>
                </div>
                <div class="text-sm mt-2 space-y-1">
                    <p id="rule-length" class="text-red-300">✗ Au moins 8 caractères</p>
                    <p id="rule-uppercase" class="text-red-300">✗ Une majuscule</p>
                    <p id="rule-number" class="text-red-300">✗ Un chiffre</p>
                </div>
            </div>

            <div>
                <label class="block mb-1 font-semibold text-sm">Confirmer le mot de passe <span class="text-red-300">*</span></label>
                <div class="relative">
                    <input type="password" name="password_confirm" id="password_confirm"
                           class="w-full border border-gray-300 text-white bg-white/10 p-2 rounded pr-10 focus:outline-none focus:ring-2 focus:ring-white"
                           placeholder="••••••••" required>
                    <button type="button" onclick="togglePassword(this)"
                            class="absolute right-2 top-2 text-white/70 hover:text-white">👁</button>
                </div>
                <p id="rule-match" class="text-red-300 text-sm mt-1">✗ Les mots de passe correspondent</p>
            </div>

            <button type="submit"
                    class="w-full bg-white text-[#3B0764] font-semibold py-2 rounded hover:bg-gray-100 transition">
                Créer mon compte ✓
            </button>
        </form>
    </div>
</div>

<script>
function togglePassword(btn) {
    const input = btn.previousElementSibling;
    input.type = input.type === 'password' ? 'text' : 'password';
    btn.textContent = input.type === 'password' ? '👁' : '🙈';
}

document.addEventListener('DOMContentLoaded', function() {
    const password = document.getElementById('password');
    const confirm  = document.getElementById('password_confirm');

    function updateRule(id, valid) {
        const el = document.getElementById(id);
        if (!el) return;
        const text = el.textContent.slice(2);
        el.className = valid ? 'text-green-300 text-sm' : 'text-red-300 text-sm';
        el.textContent = (valid ? '✓ ' : '✗ ') + text;
    }

    password.addEventListener('input', function() {
        updateRule('rule-length',   password.value.length >= 8);
        updateRule('rule-uppercase', /[A-Z]/.test(password.value));
        updateRule('rule-number',    /[0-9]/.test(password.value));
        updateRule('rule-match',     password.value.length > 0 && password.value === confirm.value);
    });

    confirm.addEventListener('input', function() {
        updateRule('rule-match', password.value.length > 0 && password.value === confirm.value);
    });
});
</script>
{% endblock %}