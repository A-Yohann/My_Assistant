<form method="post">
    {% if step == 1 %}
        <label for="email" class="block text-white mb-1">Email</label>
        <input type="email" name="email" id="email" class="block w-full border p-2 mb-4 rounded" placeholder="Email" value="{{ formData.email|default('') }}" required>
        <div class="flex justify-between">
            <button type="submit" class="bg-black text-white px-4 py-2 rounded">Suivant</button>
        </div>
    {% elseif step == 2 %}
        <label for="email" class="block text-white mb-1">Email</label>
        <input type="email" name="email" id="email" class="block w-full border p-2 mb-4 rounded bg-gray-200" value="{{ formData.email|default('') }}" readonly>
        <label for="password" class="block text-white mb-1">Mot de passe</label>
        <input type="password" name="password" id="password" class="block w-full border p-2 mb-4 rounded" placeholder="Mot de passe" required>
        <label for="password_confirm" class="block text-white mb-1">Confirmation du mot de passe</label>
        <input type="password" name="password_confirm" id="password_confirm" class="block w-full border p-2 mb-4 rounded" placeholder="Confirmez le mot de passe" required>
        <div class="flex justify-between">
            <a href="{{ path('app_register_multi', {'step': 1}) }}" class="bg-black text-white px-4 py-2 rounded">Retour</a>
            <button type="submit" class="bg-black text-white px-4 py-2 rounded">Valider</button>
        </div>
    {% endif %}
</form>
{% for flash_error in app.flashes('error') %}
    <div class="bg-red-600 text-white p-2 mt-4 rounded">{{ flash_error }}</div>
{% endfor %}
{% for flash_success in app.flashes('success') %}
    <div class="bg-green-600 text-white p-2 mt-4 rounded">{{ flash_success }}</div>
{% endfor %}
