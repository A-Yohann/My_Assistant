{% extends 'base.html.twig' %}

{% block title %}Liste des factures{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl mt-6 lg:mt-10 bg-white p-4 lg:p-8 rounded shadow mx-4 lg:mx-auto">

    <h1 class="text-xl lg:text-2xl font-bold mb-6">Liste des factures</h1>

    <!-- Filtres -->
    <form method="GET" action="{{ path('facture_index') }}" class="flex flex-col sm:flex-row gap-3 mb-6">
        <input type="text" name="search" value="{{ search }}"
               placeholder="🔍 Rechercher par numéro..."
               class="flex-1 border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]">

        <select name="statut" class="border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764] bg-white">
            <option value="">Tous les statuts</option>
            <option value="impayee" {% if statut == 'impayee' %}selected{% endif %}>Impayée</option>
            <option value="payee" {% if statut == 'payee' %}selected{% endif %}>Payée</option>
        </select>

        <button type="submit" class="bg-[#3B0764] text-white px-4 py-2 rounded-lg text-sm hover:opacity-90">
            Filtrer
        </button>

        {% if search or statut %}
            <a href="{{ path('facture_index') }}" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-300">
                Réinitialiser
            </a>
        {% endif %}
    </form>

    <!-- Table desktop -->
    <div class="hidden md:block overflow-x-auto">
        <table class="min-w-full bg-white">
            <thead>
                <tr class="bg-[#3B0764] text-white">
                    <th class="px-4 py-2 text-left">Numéro</th>
                    <th class="px-4 py-2 text-left">Date création</th>
                    <th class="px-4 py-2 text-left">Date échéance</th>
                    <th class="px-4 py-2 text-left">Montant TTC</th>
                    <th class="px-4 py-2 text-left">Statut</th>
                    <th class="px-4 py-2 text-left">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for facture in factures %}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="px-4 py-2 font-medium">{{ facture.numeroFacture }}</td>
                        <td class="px-4 py-2">{{ facture.dateCreation|date('d/m/Y') }}</td>
                        <td class="px-4 py-2">{{ facture.dateEcheance ? facture.dateEcheance|date('d/m/Y') : '-' }}</td>
                        <td class="px-4 py-2">{{ facture.montantTtc }} €</td>
                        <td class="px-4 py-2">
                            {% if facture.etat == 'impayee' %}
                                <span class="bg-red-100 text-red-800 text-xs font-semibold px-2 py-1 rounded">Impayée</span>
                            {% elseif facture.etat == 'payee' %}
                                <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Payée</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-2">
                            <a href="{{ path('facture_show', {'id': facture.id}) }}" class="text-blue-600 hover:underline text-sm">Voir</a>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="text-center py-4 text-gray-400">Aucune facture trouvée.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Cards mobile -->
    <div class="md:hidden space-y-3">
        {% for facture in factures %}
            <div class="border rounded-lg p-4 bg-gray-50">
                <div class="flex justify-between items-start mb-2">
                    <span class="font-bold text-[#231F20]">{{ facture.numeroFacture }}</span>
                    {% if facture.etat == 'impayee' %}
                        <span class="bg-red-100 text-red-800 text-xs font-semibold px-2 py-1 rounded">Impayée</span>
                    {% elseif facture.etat == 'payee' %}
                        <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Payée</span>
                    {% endif %}
                </div>
                <div class="text-sm text-gray-600 mb-1">📅 Créée le : <span class="font-medium">{{ facture.dateCreation|date('d/m/Y') }}</span></div>
                <div class="text-sm text-gray-600 mb-1">⏰ Échéance : <span class="font-medium">{{ facture.dateEcheance ? facture.dateEcheance|date('d/m/Y') : '-' }}</span></div>
                <div class="text-sm text-gray-600 mb-3">💰 TTC : <span class="font-medium">{{ facture.montantTtc }} €</span></div>
                <a href="{{ path('facture_show', {'id': facture.id}) }}"
                   class="block text-center bg-[#3B0764] text-white text-sm px-4 py-2 rounded hover:opacity-90">
                    Voir la facture
                </a>
            </div>
        {% else %}
            <p class="text-center text-gray-400 py-4">Aucune facture trouvée.</p>
        {% endfor %}
    </div>
</div>
<!-- Pagination -->
    <div class="flex justify-center mt-6">
        {{ knp_pagination_render(factures) }}
    </div>
{% endblock %}