<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Facture {{ numero }}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; font-size: 13px; color: #1a1a1a; padding: 30px; }
        .header { width: 100%; margin-bottom: 30px; }
        .header-left { float: left; width: 48%; }
        .header-right { float: right; width: 48%; text-align: right; }
        .clear { clear: both; }
        .entreprise-nom { font-size: 16px; font-weight: bold; margin-bottom: 5px; }
        .client-label { font-weight: bold; margin-bottom: 5px; color: #3B0764; }
        .titre { font-size: 22px; font-weight: bold; color: #3B0764; margin: 30px 0 15px 0; border-bottom: 2px solid #3B0764; padding-bottom: 8px; }
        .infos { margin-bottom: 20px; }
        .infos p { margin-bottom: 4px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        thead tr { background-color: #3B0764; color: white; }
        th { padding: 10px 8px; text-align: left; }
        td { padding: 8px; border-bottom: 1px solid #ddd; }
        tbody tr:nth-child(even) { background-color: #f9f9f9; }
        .totaux { width: 40%; float: right; margin-top: 10px; }
        .totaux table { border: none; }
        .totaux td { border: none; padding: 4px 8px; }
        .totaux .total-ttc { font-weight: bold; font-size: 15px; color: #3B0764; border-top: 2px solid #3B0764; }
        .conditions { margin-top: 40px; font-size: 12px; color: #666; }
        .badge-impayee { color: #dc2626; font-weight: bold; }
        .badge-payee { color: #16a34a; font-weight: bold; }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-left">
            <div class="entreprise-nom">{{ entreprise_nom }}</div>
            <div>{{ entreprise_adresse }}</div>
            <div>Tél : {{ entreprise_tel }}</div>
            <div>Email : {{ entreprise_email }}</div>
        </div>
        <div class="header-right">
            <div class="client-label">Destinataire :</div>
            <div><strong>{{ client_nom }} {{ client_prenom }}</strong></div>
            <div>{{ client_adresse }}</div>
            <div>Tél : {{ client_telephone }}</div>
            <div>Email : {{ client_email }}</div>
        </div>
        <div class="clear"></div>
    </div>

    <div class="titre">Facture</div>

    <div class="infos">
        <p><strong>Numéro :</strong> {{ numero }}</p>
        <p><strong>Date :</strong> {{ date }}</p>
        <p><strong>Date d'échéance :</strong> {{ dateEcheance }}</p>
    </div>

    <table>
        <thead>
            <tr>
                <th>Libellé</th>
                <th>Quantité</th>
                <th>Prix unitaire</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            {% for article in articles %}
                <tr>
                    <td>{{ article.libelle }}</td>
                    <td>{{ article.qty }}</td>
                    <td>{{ article.price }} €</td>
                    <td>{{ (article.qty * article.price)|number_format(2) }} €</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <div class="totaux">
        <table>
            <tr><td>Total HT :</td><td><strong>{{ totalHT }} €</strong></td></tr>
            <tr><td>TVA :</td><td><strong>{{ tva }} €</strong></td></tr>
            <tr class="total-ttc"><td>Total TTC :</td><td><strong>{{ totalTTC }} €</strong></td></tr>
        </table>
    </div>
    <div class="clear"></div>

    <div class="conditions"><strong>Conditions :</strong> Paiement sous 30 jours.</div>
</body>
</html>