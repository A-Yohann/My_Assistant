{% extends 'base.html.twig' %}

{% block title %}Client {{ client.nom }} {{ client.prenom }}{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl mt-10 bg-white p-8 rounded shadow">
    <h1 class="text-2xl font-bold mb-6">Fiche client</h1>

    <table class="min-w-full bg-white mb-8">
        <tr class="border-b"><th class="text-left px-4 py-2 w-40">Nom</th><td class="px-4 py-2">{{ client.nom }}</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Prénom</th><td class="px-4 py-2">{{ client.prenom }}</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Email</th><td class="px-4 py-2">{{ client.email }}</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Téléphone</th><td class="px-4 py-2">{{ client.telephone }}</td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Adresse</th><td class="px-4 py-2">
            {{ client.numeroRue }} {{ client.nomRue }},
            {{ client.codePostal }} {{ client.ville }},
            {{ client.pays }}
        </td></tr>
        <tr class="border-b"><th class="text-left px-4 py-2">Date création</th><td class="px-4 py-2">{{ client.dateCreation|date('d/m/Y') }}</td></tr>
    </table>

    <h2 class="text-xl font-bold mb-4">Devis associés</h2>
    {% if devis is not empty %}
        <table class="min-w-full bg-white mb-6">
            <thead>
                <tr class="bg-[#3B0764] text-white">
                    <th class="px-4 py-2 text-left">Numéro</th>
                    <th class="px-4 py-2 text-left">Date</th>
                    <th class="px-4 py-2 text-left">Montant TTC</th>
                    <th class="px-4 py-2 text-left">Statut</th>
                    <th class="px-4 py-2 text-left">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for d in devis %}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="px-4 py-2">{{ d.numeroDevis }}</td>
                        <td class="px-4 py-2">{{ d.dateCreation|date('d/m/Y') }}</td>
                        <td class="px-4 py-2">{{ d.montantTtc|number_format(2, ',', ' ') }} €</td>
                        <td class="px-4 py-2">
                            {% if d.etat == 'en_attente' %}
                                <span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2 py-1 rounded">En attente</span>
                            {% elseif d.etat == 'valide' %}
                                <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Validé</span>
                            {% elseif d.etat == 'paye' %}
                                <span class="bg-purple-100 text-purple-800 text-xs font-semibold px-2 py-1 rounded">Payé</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-2">
                            <a href="{{ path('devis_show', {'id': d.id}) }}" class="text-blue-600 hover:underline">Voir</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="text-gray-400">Aucun devis associé à ce client.</p>
    {% endif %}

    <a href="{{ path('client_index') }}" class="bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300">
        ← Retour à la liste
    </a>
</div>
{% endblock %}