{% extends 'base.html.twig' %}

{% block title %}Client {{ client.nom }} {{ client.prenom }}{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl mt-6 lg:mt-10 px-4 mb-10">
    <div class="bg-white rounded-xl shadow p-4 lg:p-8 mb-6">
        <h1 class="text-xl lg:text-2xl font-bold mb-6">Fiche client</h1>

        <!-- Mobile -->
        <div class="md:hidden space-y-2 mb-6">
            <div class="flex justify-between py-2 border-b">
                <span class="text-sm font-semibold text-gray-600">Nom</span>
                <span class="text-sm">{{ client.nom }}</span>
            </div>
            <div class="flex justify-between py-2 border-b">
                <span class="text-sm font-semibold text-gray-600">Prénom</span>
                <span class="text-sm">{{ client.prenom }}</span>
            </div>
            <div class="flex justify-between py-2 border-b">
                <span class="text-sm font-semibold text-gray-600">Email</span>
                <span class="text-sm">{{ client.email }}</span>
            </div>
            <div class="flex justify-between py-2 border-b">
                <span class="text-sm font-semibold text-gray-600">Téléphone</span>
                <span class="text-sm">{{ client.telephone }}</span>
            </div>
            <div class="py-2 border-b">
                <span class="text-sm font-semibold text-gray-600 block mb-1">Adresse</span>
                <span class="text-sm text-gray-700">{{ client.numeroRue }} {{ client.nomRue }}, {{ client.codePostal }} {{ client.ville }}, {{ client.pays }}</span>
            </div>
            <div class="flex justify-between py-2 border-b">
                <span class="text-sm font-semibold text-gray-600">Date création</span>
                <span class="text-sm">{{ client.dateCreation|date('d/m/Y') }}</span>
            </div>
        </div>

        <!-- Desktop -->
        <table class="hidden md:table min-w-full bg-white mb-6">
            <tr class="border-b"><th class="text-left px-4 py-2 w-40">Nom</th><td class="px-4 py-2">{{ client.nom }}</td></tr>
            <tr class="border-b"><th class="text-left px-4 py-2">Prénom</th><td class="px-4 py-2">{{ client.prenom }}</td></tr>
            <tr class="border-b"><th class="text-left px-4 py-2">Email</th><td class="px-4 py-2">{{ client.email }}</td></tr>
            <tr class="border-b"><th class="text-left px-4 py-2">Téléphone</th><td class="px-4 py-2">{{ client.telephone }}</td></tr>
            <tr class="border-b"><th class="text-left px-4 py-2">Adresse</th><td class="px-4 py-2">
                {{ client.numeroRue }} {{ client.nomRue }},
                {{ client.codePostal }} {{ client.ville }},
                {{ client.pays }}
            </td></tr>
            <tr class="border-b"><th class="text-left px-4 py-2">Date création</th><td class="px-4 py-2">{{ client.dateCreation|date('d/m/Y') }}</td></tr>
        </table>

        <h2 class="text-lg lg:text-xl font-bold mb-4">Devis associés</h2>

        {% if devis is not empty %}
            <!-- Table desktop -->
            <div class="hidden md:block overflow-x-auto">
                <table class="min-w-full bg-white mb-6">
                    <thead>
                        <tr class="bg-[#3B0764] text-white">
                            <th class="px-4 py-2 text-left">Numéro</th>
                            <th class="px-4 py-2 text-left">Date</th>
                            <th class="px-4 py-2 text-left">Montant TTC</th>
                            <th class="px-4 py-2 text-left">Statut</th>
                            <th class="px-4 py-2 text-left">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for d in devis %}
                            <tr class="border-b hover:bg-gray-50">
                                <td class="px-4 py-2">{{ d.numeroDevis }}</td>
                                <td class="px-4 py-2">{{ d.dateCreation|date('d/m/Y') }}</td>
                                <td class="px-4 py-2">{{ d.montantTtc|number_format(2, ',', ' ') }} €</td>
                                <td class="px-4 py-2">
                                    {% if d.etat == 'en_attente' %}
                                        <span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2 py-1 rounded">En attente</span>
                                    {% elseif d.etat == 'valide' %}
                                        <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Validé</span>
                                    {% elseif d.etat == 'paye' %}
                                        <span class="bg-purple-100 text-purple-800 text-xs font-semibold px-2 py-1 rounded">Payé</span>
                                    {% endif %}
                                </td>
                                <td class="px-4 py-2">
                                    <a href="{{ path('devis_show', {'id': d.id}) }}" class="text-blue-600 hover:underline text-sm">Voir</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <!-- Cards mobile -->
            <div class="md:hidden space-y-3 mb-6">
                {% for d in devis %}
                    <div class="border rounded-lg p-4 bg-gray-50">
                        <div class="flex justify-between items-start mb-2">
                            <span class="font-bold text-sm text-[#231F20]">{{ d.numeroDevis }}</span>
                            {% if d.etat == 'en_attente' %}
                                <span class="bg-yellow-100 text-yellow-800 text-xs font-semibold px-2 py-1 rounded">En attente</span>
                            {% elseif d.etat == 'valide' %}
                                <span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-1 rounded">Validé</span>
                            {% elseif d.etat == 'paye' %}
                                <span class="bg-purple-100 text-purple-800 text-xs font-semibold px-2 py-1 rounded">Payé</span>
                            {% endif %}
                        </div>
                        <div class="text-sm text-gray-600 mb-1">📅 {{ d.dateCreation|date('d/m/Y') }}</div>
                        <div class="text-sm text-gray-600 mb-3">💰 {{ d.montantTtc|number_format(2, ',', ' ') }} €</div>
                        <a href="{{ path('devis_show', {'id': d.id}) }}"
                           class="block text-center bg-[#3B0764] text-white text-sm px-4 py-2 rounded hover:opacity-90">
                            Voir le devis
                        </a>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-gray-400 text-sm mb-6">Aucun devis associé à ce client.</p>
        {% endif %}

        <a href="{{ path('client_index') }}" class="bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300 text-sm">
            ← Retour à la liste
        </a>
    </div>
</div>
{% endblock %}