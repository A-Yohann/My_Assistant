{% extends 'base.html.twig' %}

{% block title %}Liste des clients{% endblock %}

{% block body %}
<div class="container mx-auto max-w-4xl mt-6 lg:mt-10 px-4 mb-10">
    <div class="bg-white rounded-xl shadow p-4 lg:p-8">
        <h1 class="text-xl lg:text-2xl font-bold mb-6">Liste des clients</h1>

        <!-- Table desktop -->
        <div class="hidden md:block overflow-x-auto">
            <table class="min-w-full bg-white">
                <thead>
                    <tr class="bg-[#3B0764] text-white">
                        <th class="px-4 py-2 text-left">Nom</th>
                        <th class="px-4 py-2 text-left">Prénom</th>
                        <th class="px-4 py-2 text-left">Email</th>
                        <th class="px-4 py-2 text-left">Téléphone</th>
                        <th class="px-4 py-2 text-left">Ville</th>
                        <th class="px-4 py-2 text-left">Date création</th>
                        <th class="px-4 py-2 text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for client in clients %}
                        <tr class="border-b hover:bg-gray-50">
                            <td class="px-4 py-2">{{ client.nom }}</td>
                            <td class="px-4 py-2">{{ client.prenom }}</td>
                            <td class="px-4 py-2">{{ client.email }}</td>
                            <td class="px-4 py-2">{{ client.telephone }}</td>
                            <td class="px-4 py-2">{{ client.ville ?? '-' }}</td>
                            <td class="px-4 py-2">{{ client.dateCreation|date('d/m/Y') }}</td>
                            <td class="px-4 py-2">
                                <a href="{{ path('client_show', {'id': client.idClient}) }}" class="text-blue-600 hover:underline text-sm">Voir</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr><td colspan="7" class="text-center py-4 text-gray-400">Aucun client trouvé.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Cards mobile -->
        <div class="md:hidden space-y-3">
            {% for client in clients %}
                <div class="border rounded-lg p-4 bg-gray-50">
                    <div class="flex justify-between items-start mb-2">
                        <span class="font-bold text-sm text-[#231F20]">{{ client.nom }} {{ client.prenom }}</span>
                        <span class="text-xs text-gray-400">{{ client.dateCreation|date('d/m/Y') }}</span>
                    </div>
                    <div class="text-sm text-gray-600 mb-1">📧 {{ client.email }}</div>
                    <div class="text-sm text-gray-600 mb-1">📞 {{ client.telephone }}</div>
                    <div class="text-sm text-gray-600 mb-3">📍 {{ client.ville ?? '-' }}</div>
                    <a href="{{ path('client_show', {'id': client.idClient}) }}"
                       class="block text-center bg-[#3B0764] text-white text-sm px-4 py-2 rounded hover:opacity-90">
                        Voir la fiche
                    </a>
                </div>
            {% else %}
                <p class="text-center text-gray-400 py-4 text-sm">Aucun client trouvé.</p>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}