{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="flex justify-center py-12 px-4">
    <div class="bg-[#3B0764] text-[#f2F2F2] rounded-xl shadow-xl max-w-md w-full p-10 space-y-6">

        <h1 class="text-3xl font-bold text-center">Mot de passe oublié</h1>



        <form method="post" class="space-y-4">

            <div>
                <label for="email" class="block mb-1 font-semibold">Email</label>
                <input type="email"
                       name="email"
                       id="email"
                       class="w-full border border-gray-300 text-white bg-transparent p-2 rounded"
                       required>
            </div>

            <button type="submit"
                    class="w-full bg-white text-[#3B0764] font-semibold py-2 rounded hover:bg-gray-100 transition">
                Envoyer le lien
            </button>

        </form>

    </div>
</div>
{% endblock %}
