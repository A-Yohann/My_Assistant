{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
    <h1 class="mb-6 text-center py-4">Réinitialiser le mot de passe</h1>
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="p-4 rounded mb-6 {{ label == 'success' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}
    <form method="post" class="max-w-md mx-auto p-6 border rounded bg-gray-50">
        <label for="password" class="block mb-1">Nouveau mot de passe</label>
        <input type="password" name="password" id="password" class="block w-full border p-2 mb-4 rounded" required>
        <div class="flex justify-center">
            <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Réinitialiser</button>
        </div>
    </form>
{% endblock %}
