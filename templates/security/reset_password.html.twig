{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
<div class="flex justify-center py-12 px-4">
    <div class="bg-[#3B0764] text-[#f2F2F2] rounded-xl shadow-xl max-w-md w-full p-10 space-y-6">

        <h1 class="text-3xl font-bold text-center">
            Réinitialiser le mot de passe
        </h1>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="p-3 rounded text-sm text-center
                    {{ label == 'success' ? 'bg-green-500 text-white' : 'bg-red-500 text-white' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <form method="post" class="space-y-4">

            <div>
                <label for="password" class="block mb-1 font-semibold">
                    Nouveau mot de passe
                </label>
                <input type="password"
                       name="password"
                       id="password"
                              pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z\d]).{8,}$"

                       class="w-full border border-gray-300 text-[#f2F2F2] p-2 rounded"
                       required>
<div class="text-sm mt-2 space-y-1">
    <p id="rule-length" class="text-red-300">✗ Au moins 8 caractères</p>
    <p id="rule-lowercase" class="text-red-300">✗ Une minuscule</p>
    <p id="rule-uppercase" class="text-red-300">✗ Une majuscule</p>
    <p id="rule-number" class="text-red-300">✗ Un chiffre</p>
    <p id="rule-special" class="text-red-300">✗ Un caractère spécial</p>
</div>

            </div>
<button type="submit"
        id="submitBtn"
        disabled
        class="w-full bg-white text-[#3B0764] font-semibold py-2 rounded hover:bg-gray-100 transition disabled:opacity-50 disabled:cursor-not-allowed">
    Réinitialiser
</button>

        </form>

    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const password = document.getElementById('password');
    const submitBtn = document.getElementById('submitBtn');

    function updateRule(id, valid) {
        const el = document.getElementById(id);
        if (!el) return;
        const text = el.textContent.slice(2);
        el.className = valid ? 'text-green-300 text-sm' : 'text-red-300 text-sm';
        el.textContent = (valid ? '✓ ' : '✗ ') + text;
    }

    password.addEventListener('input', function() {
        const value = password.value;

        const rules = {
            length: value.length >= 8,
            lowercase: /[a-z]/.test(value),
            uppercase: /[A-Z]/.test(value),
            number: /[0-9]/.test(value),
            special: /[^A-Za-z0-9]/.test(value)
        };

        updateRule('rule-length', rules.length);
        updateRule('rule-lowercase', rules.lowercase);
        updateRule('rule-uppercase', rules.uppercase);
        updateRule('rule-number', rules.number);
        updateRule('rule-special', rules.special);

        // Active le bouton si tout est OK
        const isValid = Object.values(rules).every(Boolean);
        submitBtn.disabled = !isValid;
    });
});
</script>
{% endblock %}
