{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
<div class="flex justify-center py-12 px-4">
    <div class="bg-[#3B0764] text-[#f2F2F2] rounded-xl shadow-xl max-w-md w-full p-10 space-y-6">

        <h1 class="text-3xl font-bold mb-4 text-center">Connexion</h1>

        {% if app.user %}
            <div class="bg-green-500 text-white p-3 rounded text-sm text-center">
                ✅ Vous êtes déjà connecté en tant que {{ app.user.userIdentifier }} <br>
                <a href="{{ logout_path() }}" class="underline">Se déconnecter</a>
            </div>
        {% else %}

            {% if error %}
                <div class="bg-red-500 text-white p-3 rounded">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" class="space-y-4">

                <div>
                    <label for="username" class="block mb-1 font-semibold">Email</label>
                    <input type="email"
                           value="{{ last_username }}"
                           name="_username"
                           id="username"
                           class="w-full border border-gray-300 text-[#f2F2F2] p-2 rounded"
                           autocomplete="email"
                           required autofocus>
                </div>

                <div>
                    <label for="password" class="block mb-1 font-semibold">Mot de passe</label>
                    <input type="password"
                           name="_password"
                           id="password"
                           class="w-full border border-gray-300 text-black p-2 rounded"
                           autocomplete="current-password"
                           required>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit"
                        class="w-full bg-white text-[#3B0764] font-semibold py-2 rounded hover:bg-gray-100 transition">
                    Se connecter
                </button>

                <div class="text-center text-sm mt-2">
                    <a href="{{ path('app_forgot_password') }}" class="underline hover:text-gray-200">
                        Mot de passe oublié ?
                    </a>
                </div>

                <div class="text-center text-sm">
                    <span>Pas encore de compte ?</span>
                    <a href="{{ path('app_register') }}" class="underline font-semibold hover:text-gray-200">
                        Inscription
                    </a>
                </div>

            </form>

        {% endif %}

    </div>
</div>
{% endblock %}
