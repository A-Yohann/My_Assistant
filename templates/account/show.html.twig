{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}
<div class="max-w-md mx-auto p-8 rounded-lg bg-purple-900 text-white">
    <div class="flex justify-center mb-6">
        <img src="{{ avatar }}" alt="Avatar" class="w-20 h-20 rounded-full object-cover">
    </div>
    <div class="mb-4">
        <strong>Email :</strong> {{ email }}
    </div>
    <div class="mb-4">
        <strong>Téléphone :</strong> {{ telephone }}
    </div>
    <div class="mb-4">
        <strong>Mot de passe :</strong> ********
    </div>
    <div class="flex justify-end">
        <a href="{{ path('account_manage') }}" class="bg-black text-white px-6 py-2 rounded">Modifier</a>
    </div>
</div>
{% endblock %}
