{% extends 'base.html.twig' %}

{% block title %}Gestion de compte{% endblock %}

{% block body %}
<div class="max-w-md mx-auto p-8 rounded-lg bg-[#3B0764] mt-10">

    {% for message in app.flashes('success') %}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-2 rounded mb-4">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-2 rounded mb-4">{{ message }}</div>
    {% endfor %}

    <form method="post" enctype="multipart/form-data" action="{{ path('account_manage') }}">

        <!-- Avatar -->
        <div class="flex justify-center mb-6">
            <label for="profile_image" class="w-20 h-20 rounded-full bg-gray-200 overflow-hidden cursor-pointer block">
                <img src="{{ avatar }}" alt="Avatar" class="w-full h-full object-cover">
                <input type="file" id="profile_image" name="profile_image" accept="image/*" class="hidden" onchange="this.form.submit()">
            </label>
        </div>

        <!-- Nom -->
        <label for="nom" class="block text-white mb-1">Nom</label>
        <input type="text" id="nom" name="nom" value="{{ user.nom ?? '' }}"
               placeholder="Votre nom" class="block w-full mb-4 p-2 rounded bg-gray-100">

        <!-- Prénom -->
        <label for="prenom" class="block text-white mb-1">Prénom</label>
        <input type="text" id="prenom" name="prenom" value="{{ user.prenom ?? '' }}"
               placeholder="Votre prénom" class="block w-full mb-4 p-2 rounded bg-gray-100">

        <!-- Email -->
        <label for="email" class="block text-white mb-1">Email</label>
        <input type="email" id="email" name="email" value="{{ user.email }}"
               placeholder="Votre email" class="block w-full mb-4 p-2 rounded bg-gray-100">

        <!-- Mot de passe -->
        <label for="password" class="block text-white mb-1">
            Nouveau mot de passe
            <span class="text-xs text-gray-300">(laisser vide pour ne pas changer)</span>
        </label>
        <input type="password" id="password" name="password"
               placeholder="Nouveau mot de passe" class="block w-full mb-4 p-2 rounded bg-gray-100">

        <!-- Téléphone -->
        <label for="telephone" class="block text-white mb-1">Téléphone</label>
        <input type="text" id="telephone" name="telephone" value="{{ user.telephone ?? '' }}"
               placeholder="Votre téléphone" class="block w-full mb-6 p-2 rounded bg-gray-100">

        <div class="flex justify-between">
            <a href="{{ path('dashboard') }}" class="bg-black text-white px-6 py-2 rounded">Annuler</a>
            <button type="submit" class="bg-black text-white px-6 py-2 rounded">Modifier</button>
        </div>

    <div class="flex justify-center mt-5">
    <button type="submit" name="action" value="delete"
            class="bg-red-500 text-white px-6 py-2 rounded"
            onclick="return confirm('Êtes-vous sûr de vouloir supprimer votre compte ? Cette action est irréversible.')">
        Supprimer
    </button>
</div>

        
    </form>
</div>
{% endblock %}