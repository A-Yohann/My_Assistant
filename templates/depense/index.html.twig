{% extends 'base.html.twig' %}

{% block title %}Dépenses{% endblock %}

{% block body %}
<div class="container mx-auto max-w-6xl mt-6 lg:mt-10 px-4 mb-10">
    <a href="{{ path('dashboard') }}" class="bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300 text-sm mb-4 inline-block">
        ← Tableau de bord
    </a>
    <h1 class="text-xl lg:text-2xl font-bold mb-6">Gestion des dépenses</h1>

    <!-- Formulaire + Diagramme -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

        <!-- Formulaire ajout -->
        <div class="bg-white p-4 lg:p-6 rounded shadow">
            <h2 class="text-lg font-bold mb-4">Ajouter une dépense</h2>
            {{ form_start(form, {'attr': {'class': 'space-y-4', 'enctype': 'multipart/form-data'}}) }}

                <div>
                    {{ form_label(form.libelle, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.libelle, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': 'Ex: Achat stylos'}}) }}
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        {{ form_label(form.montant, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.montant, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]', 'placeholder': '0.00'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.quantite, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.quantite, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                    </div>
                </div>

                <div>
                    {{ form_label(form.dateDepense, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.dateDepense, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764]'}}) }}
                </div>

                <div>
                    {{ form_label(form.categorie, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.categorie, {'attr': {'class': 'block w-full border border-gray-300 rounded-lg p-2 text-sm focus:outline-none focus:ring-2 focus:ring-[#3B0764] bg-white'}}) }}
                </div>

                <!-- ✅ Upload justificatif -->
                <div>
                    {{ form_label(form.justificatif, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    <div class="border-2 border-dashed border-gray-300 rounded-lg p-4 bg-gray-50 hover:bg-gray-100 transition cursor-pointer">
                        {{ form_widget(form.justificatif) }}
                        <p class="text-xs text-gray-400 mt-1 text-center">PDF, PNG, JPG acceptés</p>
                    </div>
                </div>

                <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg border border-gray-200">
                    {{ form_widget(form.moyenPaiement, {'attr': {'class': 'w-4 h-4 accent-[#3B0764]'}}) }}
                    {{ form_label(form.moyenPaiement, null, {'label_attr': {'class': 'text-sm font-medium text-gray-700 cursor-pointer'}}) }}
                </div>

                <div class="flex justify-end">
                    <button type="submit" class="bg-[#3B0764] text-white px-6 py-2 rounded-lg hover:opacity-90 font-semibold text-sm">
                        Ajouter
                    </button>
                </div>

            {{ form_end(form) }}
        </div>

        <!-- Diagramme circulaire -->
        <div class="bg-white p-4 lg:p-6 rounded shadow flex flex-col items-center">
            <h2 class="text-lg font-bold mb-4">Répartition par catégorie</h2>
            {% if dataParCategorie is not empty %}
                <canvas id="depenseChart" style="max-height: 250px;"></canvas>
                <div class="mt-4 flex flex-wrap gap-2 justify-center">
                    {% for item in dataParCategorie %}
                        <span class="text-xs px-2 py-1 rounded text-white font-semibold"
                              style="background-color: {{ item.couleur }}">
                            {{ item.categorie }} — {{ item.total }} €
                        </span>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-gray-400 mt-10 text-sm">Aucune dépense enregistrée.</div>
            {% endif %}
        </div>
    </div>

    <!-- Liste des dépenses -->
    <div class="bg-white p-4 lg:p-6 rounded shadow">
        <h2 class="text-lg font-bold mb-4">Liste des dépenses</h2>

        <!-- Table desktop -->
        <div class="hidden md:block overflow-x-auto">
            <table class="min-w-full">
                <thead>
                    <tr class="bg-[#3B0764] text-white">
                        <th class="px-4 py-2 text-left">Date</th>
                        <th class="px-4 py-2 text-left">Libellé</th>
                        <th class="px-4 py-2 text-left">Catégorie</th>
                        <th class="px-4 py-2 text-left">Qté</th>
                        <th class="px-4 py-2 text-left">Montant unitaire</th>
                        <th class="px-4 py-2 text-left">Total</th>
                        <th class="px-4 py-2 text-left">Paiement</th>
                        <th class="px-4 py-2 text-left">Justificatif</th>
                        <th class="px-4 py-2 text-left">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for depense in depenses %}
                        <tr class="border-b hover:bg-gray-50">
                            <td class="px-4 py-2 text-sm">{{ depense.dateDepense|date('d/m/Y') }}</td>
                            <td class="px-4 py-2 text-sm">{{ depense.libelle }}</td>
                            <td class="px-4 py-2">
                                <span class="text-xs px-2 py-1 rounded text-white font-semibold"
                                      style="background-color: {{ categories[depense.categorie] ?? '#8b5cf6' }}">
                                    {{ depense.categorie }}
                                </span>
                            </td>
                            <td class="px-4 py-2 text-sm">{{ depense.quantite }}</td>
                            <td class="px-4 py-2 text-sm">{{ depense.montant }} €</td>
                            <td class="px-4 py-2 text-sm font-semibold">{{ (depense.montant * depense.quantite)|number_format(2, ',', ' ') }} €</td>
                            <td class="px-4 py-2">
                                {% if depense.moyenPaiement %}
                                    <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">Carte</span>
                                {% else %}
                                    <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">Espèces</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-2">
                                {% if depense.justificatif %}
                                    <a href="{{ depense.justificatif }}" target="_blank"
                                       class="text-blue-600 hover:underline text-xs">
                                        📎 Voir
                                    </a>
                                {% else %}
                                    <span class="text-gray-400 text-xs">—</span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-2">
                                <a href="{{ path('depense_supprimer', {'id': depense.idDepense}) }}"
                                   class="text-red-600 hover:underline text-sm"
                                   onclick="return confirm('Supprimer cette dépense ?')">
                                    Supprimer
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="9" class="text-center py-4 text-gray-400">Aucune dépense trouvée.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Cards mobile -->
        <div class="md:hidden space-y-3">
            {% for depense in depenses %}
                <div class="border rounded-lg p-4 bg-gray-50">
                    <div class="flex justify-between items-start mb-2">
                        <span class="font-bold text-sm text-[#231F20]">{{ depense.libelle }}</span>
                        <span class="text-xs px-2 py-1 rounded text-white font-semibold"
                              style="background-color: {{ categories[depense.categorie] ?? '#8b5cf6' }}">
                            {{ depense.categorie }}
                        </span>
                    </div>
                    <div class="text-sm text-gray-600 mb-1">📅 {{ depense.dateDepense|date('d/m/Y') }}</div>
                    <div class="text-sm text-gray-600 mb-1">Qté : <span class="font-medium">{{ depense.quantite }}</span></div>
                    <div class="text-sm text-gray-600 mb-1">Prix unitaire : <span class="font-medium">{{ depense.montant }} €</span></div>
                    <div class="text-sm text-gray-600 mb-2">Total : <span class="font-bold text-[#231F20]">{{ (depense.montant * depense.quantite)|number_format(2, ',', ' ') }} €</span></div>
                    {% if depense.justificatif %}
                        <a href="{{ depense.justificatif }}" target="_blank"
                           class="text-blue-600 hover:underline text-xs block mb-2">
                            📎 Voir le justificatif
                        </a>
                    {% endif %}
                    <div class="flex justify-between items-center">
                        {% if depense.moyenPaiement %}
                            <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">Carte</span>
                        {% else %}
                            <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">Espèces</span>
                        {% endif %}
                        <a href="{{ path('depense_supprimer', {'id': depense.idDepense}) }}"
                           class="text-red-600 hover:underline text-sm"
                           onclick="return confirm('Supprimer cette dépense ?')">
                            Supprimer
                        </a>
                    </div>
                </div>
            {% else %}
                <p class="text-center text-gray-400 py-4 text-sm">Aucune dépense trouvée.</p>
            {% endfor %}
        </div>
    </div>
</div>

{% if dataParCategorie is not empty %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('depenseChart').getContext('2d');
    new Chart(ctx, {
        type: 'pie',
        data: {
            labels: [{% for item in dataParCategorie %}'{{ item.categorie }}'{% if not loop.last %},{% endif %}{% endfor %}],
            datasets: [{
                data: [{% for item in dataParCategorie %}{{ item.total }}{% if not loop.last %},{% endif %}{% endfor %}],
                backgroundColor: [{% for item in dataParCategorie %}'{{ item.couleur }}'{% if not loop.last %},{% endif %}{% endfor %}],
                borderWidth: 2,
                borderColor: '#fff',
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.label + ' : ' + context.parsed.toFixed(2) + ' €';
                        }
                    }
                }
            }
        }
    });
</script>
{% endif %}
{% endblock %}