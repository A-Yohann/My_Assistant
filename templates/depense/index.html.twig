{% extends 'base.html.twig' %}

{% block title %}Dépenses{% endblock %}

{% block body %}
<div class="container mx-auto max-w-6xl mt-10 px-4">

    {% for message in app.flashes('success') %}
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-2 rounded mb-4">{{ message }}</div>
    {% endfor %}

    <h1 class="text-2xl font-bold mb-6">Gestion des dépenses</h1>

    <div class="grid grid-cols-2 gap-6 mb-8">

        <!-- Formulaire ajout -->
        <div class="bg-white p-6 rounded shadow">
            <h2 class="text-lg font-bold mb-4">Ajouter une dépense</h2>
            {{ form_start(form) }}
            {{ form_widget(form) }}
            <div class="flex justify-end mt-4">
                <button type="submit" class="bg-[#3B0764] text-white px-6 py-2 rounded hover:opacity-90">
                    Ajouter
                </button>
            </div>
            {{ form_end(form) }}
        </div>

        <!-- Diagramme circulaire -->
        <div class="bg-white p-6 rounded shadow flex flex-col items-center">
            <h2 class="text-lg font-bold mb-4">Répartition par catégorie</h2>
            {% if dataParCategorie is not empty %}
                <canvas id="depenseChart" style="max-height: 300px;"></canvas>
                <div class="mt-4 flex flex-wrap gap-2 justify-center">
                    {% for item in dataParCategorie %}
                        <span class="text-xs px-2 py-1 rounded text-white font-semibold"
                              style="background-color: {{ item.couleur }}">
                            {{ item.categorie }} — {{ item.total }} €
                        </span>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-gray-400 mt-10">Aucune dépense enregistrée.</div>
            {% endif %}
        </div>
    </div>

    <!-- Liste des dépenses -->
    <div class="bg-white p-6 rounded shadow">
        <h2 class="text-lg font-bold mb-4">Liste des dépenses</h2>
        <table class="min-w-full">
            <thead>
                <tr class="bg-[#3B0764] text-white">
                    <th class="px-4 py-2 text-left">Date</th>
                    <th class="px-4 py-2 text-left">Libellé</th>
                    <th class="px-4 py-2 text-left">Catégorie</th>
                    <th class="px-4 py-2 text-left">Qté</th>
                    <th class="px-4 py-2 text-left">Montant unitaire</th>
                    <th class="px-4 py-2 text-left">Total</th>
                    <th class="px-4 py-2 text-left">Paiement</th>
                    <th class="px-4 py-2 text-left">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for depense in depenses %}
                    <tr class="border-b hover:bg-gray-50">
                        <td class="px-4 py-2">{{ depense.dateDepense|date('d/m/Y') }}</td>
                        <td class="px-4 py-2">{{ depense.libelle }}</td>
                        <td class="px-4 py-2">
                            <span class="text-xs px-2 py-1 rounded text-white font-semibold"
                                  style="background-color: {{ categories[depense.categorie] ?? '#8b5cf6' }}">
                                {{ depense.categorie }}
                            </span>
                        </td>
                        <td class="px-4 py-2">{{ depense.quantite }}</td>
                        <td class="px-4 py-2">{{ depense.montant }} €</td>
                        <td class="px-4 py-2 font-semibold">{{ (depense.montant * depense.quantite)|number_format(2, ',', ' ') }} €</td>
                        <td class="px-4 py-2">
                            {% if depense.moyenPaiement %}
                                <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">Carte</span>
                            {% else %}
                                <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">Espèces</span>
                            {% endif %}
                        </td>
                        <td class="px-4 py-2">
                            <a href="{{ path('depense_supprimer', {'id': depense.idDepense}) }}"
                               class="text-red-600 hover:underline text-sm"
                               onclick="return confirm('Supprimer cette dépense ?')">
                                Supprimer
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center py-4 text-gray-400">Aucune dépense trouvée.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% if dataParCategorie is not empty %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const ctx = document.getElementById('depenseChart').getContext('2d');
    new Chart(ctx, {
        type: 'pie',
        data: {
            labels: [{% for item in dataParCategorie %}'{{ item.categorie }}'{% if not loop.last %},{% endif %}{% endfor %}],
            datasets: [{
                data: [{% for item in dataParCategorie %}{{ item.total }}{% if not loop.last %},{% endif %}{% endfor %}],
                backgroundColor: [{% for item in dataParCategorie %}'{{ item.couleur }}'{% if not loop.last %},{% endif %}{% endfor %}],
                borderWidth: 2,
                borderColor: '#fff',
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.label + ' : ' + context.parsed.toFixed(2) + ' €';
                        }
                    }
                }
            }
        }
    });
</script>
{% endif %}
{% endblock %}