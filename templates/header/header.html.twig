<nav class="bg-[#231F20] text-white" x-data="{ menuOpen: false }">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-center h-16">

            <!-- Logo -->
            <div class="flex items-center">
            <a href="{{ path('app_home') }}">
                <img src="/assets/img/logo.png" alt="Logo" class="h-16 w-auto">
            </a>
            </div>

            <!-- Bouton burger (visible sur mobile/tablet) -->
            <button @click="menuOpen = !menuOpen"
                    class="lg:hidden flex flex-col justify-center items-center w-8 h-8 space-y-1.5 focus:outline-none">
                <span class="block w-6 h-0.5 bg-white transition-all" :class="menuOpen ? 'rotate-45 translate-y-2' : ''"></span>
                <span class="block w-6 h-0.5 bg-white transition-all" :class="menuOpen ? 'opacity-0' : ''"></span>
                <span class="block w-6 h-0.5 bg-white transition-all" :class="menuOpen ? '-rotate-45 -translate-y-2' : ''"></span>
            </button>

            <!-- Liens desktop (masqués sur mobile/tablet) -->
            <div class="hidden lg:flex items-center space-x-6">
                <a href="{{ path('app_home') }}" class="hover:text-gray-400 transition">Accueil</a>
                <a href="{{ path('dashboard') }}" class="hover:text-gray-400 transition">Tableau de bord</a>
                <a href="{{ path('app_entreprise') }}" class="hover:text-gray-400 transition">Mes entreprises</a>
                <a href="{{ path('app_contact') }}" class="hover:text-gray-400 transition">Contact</a>
                <a href="{{ path('notes') }}" class="hover:text-gray-400 transition">Notes</a>

                {% if app.user %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('admin') }}" class="hover:text-gray-400 transition">Admin</a>
                    {% endif %}

                    {% set entreprises = entreprisesHeader ?? [] %}
                    {% if entreprises|length > 1 %}
                        <div class="relative" x-data="{ open: false }">
                            <button @click="open = !open"
                                    class="flex items-center gap-2 bg-[#3B0764] px-3 py-1 rounded hover:opacity-90 text-sm">
                                🏢 {{ entrepriseActiveHeader ? entrepriseActiveHeader.nomEntreprise : 'Entreprise' }}
                                <span>▾</span>
                            </button>
                            <div x-show="open" @click.away="open = false"
                                 class="absolute right-0 mt-2 bg-white text-black rounded shadow-lg z-50 min-w-[180px]">
                                {% for e in entreprises %}
                                    <a href="{{ path('entreprise_switcher', {'id': e.id}) }}"
                                       class="block px-4 py-2 hover:bg-gray-100 text-sm
                                       {% if entrepriseActiveHeader and e.id == entrepriseActiveHeader.id %}font-bold text-[#3B0764]{% endif %}">
                                        {{ e.nomEntreprise }}
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    {% elseif entreprises|length == 1 %}
                        <span class="text-xs bg-[#3B0764] px-3 py-1 rounded">
                            🏢 {{ entreprises[0].nomEntreprise }}
                        </span>
                    {% endif %}

                    <a href="{{ path('account_manage') }}" class="hover:text-gray-400 transition">Mon compte</a>
                    <a href="{{ logout_path() }}" class="hover:text-gray-400 transition">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_register') }}" class="hover:text-gray-400 transition">Inscription</a>
                    <a href="{{ path('app_login') }}" class="hover:text-gray-400 transition">Connexion</a>
                {% endif %}
            </div>
        </div>

        <!-- Menu mobile (visible uniquement quand burger ouvert) -->
        <div x-show="menuOpen"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 -translate-y-2"
             x-transition:enter-end="opacity-100 translate-y-0"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100 translate-y-0"
             x-transition:leave-end="opacity-0 -translate-y-2"
             class="lg:hidden pb-4 space-y-2">

            <a href="{{ path('app_home') }}" class="block py-2 px-2 hover:bg-gray-700 rounded transition">Accueil</a>
            <a href="{{ path('dashboard') }}" class="block py-2 px-2 hover:bg-gray-700 rounded transition">Tableau de bord</a>
            <a href="{{ path('app_entreprise') }}" class="block py-2 px-2 hover:bg-gray-700 rounded transition">Mes entreprises</a>
            <a href="{{ path('app_contact') }}" class="block py-2 px-2 hover:bg-gray-700 rounded transition">Contact</a>
            <a href="{{ path('notes') }}" class="block py-2 px-2 hover:bg-gray-700 rounded transition">Notes</a>

            {% if app.user %}
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin') }}" class="block py-2 px-2 hover:bg-gray-700 rounded transition">Admin</a>
                {% endif %}

                {% set entreprises = entreprisesHeader ?? [] %}
                {% if entreprises|length > 1 %}
                    <div class="border-t border-gray-600 pt-2">
                        <p class="text-xs text-gray-400 px-2 mb-1">Changer d'entreprise :</p>
                        {% for e in entreprises %}
                            <a href="{{ path('entreprise_switcher', {'id': e.id}) }}"
                               class="block py-2 px-2 hover:bg-gray-700 rounded text-sm
                               {% if entrepriseActiveHeader and e.id == entrepriseActiveHeader.id %}font-bold text-purple-300{% endif %}">
                                🏢 {{ e.nomEntreprise }}
                            </a>
                        {% endfor %}
                    </div>
                {% elseif entreprises|length == 1 %}
                    <span class="block py-2 px-2 text-sm text-purple-300">🏢 {{ entreprises[0].nomEntreprise }}</span>
                {% endif %}

                <div class="border-t border-gray-600 pt-2">
                    <a href="{{ path('account_manage') }}" class="block py-2 px-2 hover:bg-gray-700 rounded transition">Mon compte</a>
                    <a href="{{ logout_path() }}" class="block py-2 px-2 hover:bg-gray-700 rounded transition">Déconnexion</a>
                </div>
            {% else %}
                <div class="border-t border-gray-600 pt-2">
                    <a href="{{ path('app_register') }}" class="block py-2 px-2 hover:bg-gray-700 rounded transition">Inscription</a>
                    <a href="{{ path('app_login') }}" class="block py-2 px-2 hover:bg-gray-700 rounded transition">Connexion</a>
                </div>
            {% endif %}
        </div>
    </div>
</nav>