<!DOCTYPE html>
<html>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script src="https://unpkg.com/@dotlottie/player-component@latest/dist/dotlottie-player.js"></script>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link rel="icon" type="image/png" href="/assets/img/analyses-daudience-internet.png">
        <meta name="description" content="{% block meta_description %}My Assistant – Simplifiez la gestion de votre entreprise : factures, devis, dépenses et clients.{% endblock %}">
        <title>{% block title %}Welcome!{% endblock %}</title>
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body class="min-h-screen flex flex-col">
        {% include 'header/header.html.twig' %}

        <main class="flex-1">
            <!-- ✅ Flash messages centralisés -->
            {% for message in app.flashes('success') %}
                <div class="max-w-4xl mx-auto mt-4 px-4">
                    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded flex justify-between items-center">
                        <span>✅ {{ message }}</span>
                        <button onclick="this.parentElement.parentElement.remove()" class="text-green-700 font-bold ml-4">✕</button>
                    </div>
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="max-w-4xl mx-auto mt-4 px-4">
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded flex justify-between items-center">
                        <span>❌ {{ message }}</span>
                        <button onclick="this.parentElement.parentElement.remove()" class="text-red-700 font-bold ml-4">✕</button>
                    </div>
                </div>
            {% endfor %}
            {% for message in app.flashes('info') %}
                <div class="max-w-4xl mx-auto mt-4 px-4">
                    <div class="bg-blue-100 border border-blue-400 text-blue-700 px-4 py-3 rounded flex justify-between items-center">
                        <span>ℹ️ {{ message }}</span>
                        <button onclick="this.parentElement.parentElement.remove()" class="text-blue-700 font-bold ml-4">✕</button>
                    </div>
                </div>
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
        {% include 'footer/footer.html.twig' %}
    </body>
</html>
